@{
    ViewData["Title"] = L["SA_Sub_PageTitle"];
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="page active" id="sa-page-subscriptions">

  <div class="card card-mb-16">
    <div class="card-body card-body-row">
      <div class="card-body-grow">
        <div class="card-title-strong">@L["SA_Sub_Page_Title"]</div>
        <div class="card-sub-strong">@L["SA_Sub_Page_Sub"]</div>
      </div>
      <div class="u-flex u-items-center u-gap-10 u-flex-wrap">
        <label class="form-label u-m-0">@L["SA_Sub_Page_School"]</label>
        <select id="sub-school-select" class="form-control form-control-narrow">
          <option value="">—</option>
        </select>
        <button type="button" class="btn-primary" id="sub-add-btn" disabled>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          @L["SA_Sub_Page_Add"]
        </button>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>@L["SA_Sub_Type"]</th>
            <th>@L["SA_Sub_ActivationDate"]</th>
            <th>@L["SA_Sub_ExpirationDate"]</th>
            <th>@L["SA_Sub_Page_Status"]</th>
            <th>@L["SA_Sub_Page_MaxStudents"]</th>
            <th>@L["SA_Sub_Page_MaxBuses"]</th>
            <th>@L["SA_Sub_Price"]</th>
            <th>@L["SA_Sub_Paid"]</th>
            <th>@L["SA_Sub_Remaining"]</th>
            <th class="col-actions">@L["SA_Sub_Page_Actions"]</th>
          </tr>
        </thead>
        <tbody id="sub-tbody">
          <tr><td colspan="10" class="td-empty">@L["SA_Sub_Page_PickSchool"]</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- subscription modal + sub-strings live in _SuperAdminLayout.cshtml so the
     Schools drawer can reuse them. This page just calls init() to wire the
     school-select dropdown and the per-school grid. -->
<script>
  document.addEventListener('DOMContentLoaded', async () => {
    try { await SB.translationsReady; } catch {}
    if (typeof subscriptions === 'object') subscriptions.init();
  });
</script>
