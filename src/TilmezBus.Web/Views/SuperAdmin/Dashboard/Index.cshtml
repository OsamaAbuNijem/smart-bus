@model TilmezBus.Web.Models.SuperAdminDashboardViewModel
@{
    ViewData["Title"] = L["SA_Dash_PageTitle"];
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

@*
   Server-rendered stat cards. The controller action fetches the aggregate
   via IApiClient and hands every counter to this view; nothing renders as
   "—" while the user waits for an XHR. Mirrors admin's DashboardController
   pattern. The recent-schools table at the bottom stays JS-driven because
   it benefits from the existing schools.* rendering helpers.
*@
<div class="page active" id="sa-page-overview">

  <div class="welcome-banner">
    <div class="wb-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <div class="wb-text">
      <div class="wb-title">@L["SA_Dash_Welcome"]</div>
      <div class="wb-sub">@L["SA_Dash_Subtitle"]</div>
    </div>
    <div class="wb-date" id="sa-date-chip"></div>
  </div>

  <!-- Top row: 4 single-number cards bound to Model fields. -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon bg-purple">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <div class="stat-num">@Model.TotalSchools</div>
      <div class="stat-label">@L["SA_Dash_TotalSchools"]</div>
      <div class="stat-change up">@string.Format(L["SA_Dash_SchoolsActiveSub"].Value, Model.SchoolsActiveSub)</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon bg-blue">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </div>
      <div class="stat-num">@Model.TotalBuses</div>
      <div class="stat-label">@L["SA_Dash_TotalBuses"]</div>
      <div class="stat-change up">@L["SA_Dash_AcrossAll"]</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon bg-orange">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="stat-num">@Model.TotalDriversAndAssistants</div>
      <div class="stat-label">@L["SA_Dash_Drivers_Assistants"]</div>
      <div class="stat-change up">@string.Format(L["SA_Dash_DriversBreakdown"].Value, Model.TotalDrivers, Model.TotalAssistants)</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon bg-green">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><circle cx="12" cy="5" r="2"/></svg>
      </div>
      <div class="stat-num">@Model.TotalStudents</div>
      <div class="stat-label">@L["SA_Dash_TotalStudents"]</div>
      <div class="stat-change up">@L["SA_Dash_AcrossAll"]</div>
    </div>
  </div>

  <!-- Breakdown cards: active users / today's users / today's trips. All
       three bound server-side from @Model. The grid auto-fits so the row
       wraps gracefully on narrower viewports. -->
  <div class="dash-breakdown-grid">
    <div class="card breakdown-card">
      <div class="card-header">
        <div>
          <div class="card-title">@L["SA_Dash_ActiveUsers"]</div>
          <div class="card-sub">@L["SA_Dash_ActiveUsers_Sub"]</div>
        </div>
      </div>
      <div class="card-body breakdown-stats">
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-purple">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="breakdown-num">@Model.ActiveParents</div>
          <div class="breakdown-label">@L["SA_Dash_Role_Parent"]</div>
        </div>
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-orange">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="5" r="2.5"/><path d="M4 21v-1a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v1"/></svg>
          </div>
          <div class="breakdown-num">@Model.ActiveDrivers</div>
          <div class="breakdown-label">@L["SA_Dash_Role_Driver"]</div>
        </div>
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="5" r="2.5"/><path d="M4 21v-1a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v1"/></svg>
          </div>
          <div class="breakdown-num">@Model.ActiveAssistants</div>
          <div class="breakdown-label">@L["SA_Dash_Role_Assistant"]</div>
        </div>
      </div>
    </div>

    <div class="card breakdown-card">
      <div class="card-header">
        <div>
          <div class="card-title">@L["SA_Dash_TodayUsers"]</div>
          <div class="card-sub">@L["SA_Dash_TodayUsers_Sub"]</div>
        </div>
      </div>
      <div class="card-body breakdown-stats">
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-purple">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="breakdown-num">@Model.TodayParents</div>
          <div class="breakdown-label">@L["SA_Dash_Role_Parent"]</div>
        </div>
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-orange">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="5" r="2.5"/><path d="M4 21v-1a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v1"/></svg>
          </div>
          <div class="breakdown-num">@Model.TodayDrivers</div>
          <div class="breakdown-label">@L["SA_Dash_Role_Driver"]</div>
        </div>
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="5" r="2.5"/><path d="M4 21v-1a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v1"/></svg>
          </div>
          <div class="breakdown-num">@Model.TodayAssistants</div>
          <div class="breakdown-label">@L["SA_Dash_Role_Assistant"]</div>
        </div>
      </div>
    </div>

    <div class="card breakdown-card">
      <div class="card-header">
        <div>
          <div class="card-title">@L["SA_Dash_TodayTrips"]</div>
          <div class="card-sub">@L["SA_Dash_TodayTrips_Sub"]</div>
        </div>
      </div>
      <div class="card-body breakdown-stats">
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-yellow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B8960C" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="breakdown-num">@Model.TripsScheduled</div>
          <div class="breakdown-label">@L["SA_Dash_Trip_Created"]</div>
        </div>
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </div>
          <div class="breakdown-num">@Model.TripsInProgress</div>
          <div class="breakdown-label">@L["SA_Dash_Trip_InProgress"]</div>
        </div>
        <div class="breakdown-stat">
          <div class="breakdown-icon bg-green">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div class="breakdown-num">@Model.TripsCompleted</div>
          <div class="breakdown-label">@L["SA_Dash_Trip_Ended"]</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">@L["SA_Dash_RecentTitle"]</div>
        <div class="card-sub">@L["SA_Dash_RecentSub"]</div>
      </div>
      <a class="btn-primary card-header-link" href="/SuperAdmin/Schools">@L["SA_Dash_ViewAll"]</a>
    </div>
    <div class="card-table-wrap">
      <table class="table">
        <thead><tr>
          <th>@L["SA_Schools_Col_School"]</th><th>@L["SA_Schools_Col_City"]</th><th>@L["SA_Schools_Col_Plan"]</th><th>@L["SA_Schools_Col_Activation"]</th><th>@L["SA_Schools_Col_Status"]</th>
        </tr></thead>
        <tbody id="overview-schools-tbody">
          <tr class="skel-row"><td><div class="skel skel-h-16 skel-w-140"></div></td><td><div class="skel skel-w-80"></div></td><td><div class="skel skel-w-60"></div></td><td><div class="skel skel-w-90"></div></td><td><div class="skel skel-w-55"></div></td></tr>
          <tr class="skel-row"><td><div class="skel skel-h-16"></div></td><td><div class="skel skel-w-80"></div></td><td><div class="skel skel-w-55"></div></td><td><div class="skel skel-w-90"></div></td><td><div class="skel skel-w-55"></div></td></tr>
          <tr class="skel-row"><td><div class="skel skel-h-16 skel-w-160"></div></td><td><div class="skel skel-w-90"></div></td><td><div class="skel skel-w-60"></div></td><td><div class="skel skel-w-90"></div></td><td><div class="skel skel-w-55"></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script src="~/js/superadmin/dashboard.js" asp-append-version="true"></script>
<script>
  // Stat cards are server-rendered above. JS only fetches the recent-schools
  // list — keeps using the existing /schools endpoint with a small page size.
  document.addEventListener('DOMContentLoaded', async () => {
    try { await SB.translationsReady; } catch {}
    if (typeof dashboard === 'object') dashboard.loadRecentSchools();
  });
</script>
