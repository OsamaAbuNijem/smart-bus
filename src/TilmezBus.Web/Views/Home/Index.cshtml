  <!-- ── Differentiators: auto-routing + QR trip start ─── -->
  <section class="section diff-section" id="how">
    <div class="section-inner">
      <div class="section-eyebrow">@L["Home_Diff_Eyebrow"]</div>
      <h2 class="section-title">@L["Home_Diff_Title"]</h2>
      <p class="section-lead">@L["Home_Diff_Lead"]</p>

      <div class="diff-grid">
        <!-- 1. Smart auto-routing -->
        <article class="diff-card">
          <div class="diff-visual diff-visual-route" aria-hidden="true">
            <svg viewBox="0 0 360 200" preserveAspectRatio="xMidYMid meet">
              <defs>
                <pattern id="diffgrid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
                  <path d="M0 20 H40 M20 0 V40" stroke="#E2E8F0" stroke-width="1" fill="none"/>
                </pattern>
                <linearGradient id="diffroute" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="#F5B400"/>
                  <stop offset="100%" stop-color="#FFA500"/>
                </linearGradient>
              </defs>
              <rect width="360" height="200" fill="url(#diffgrid)"/>
              <!-- Three home → school auto-drawn paths -->
              <path d="M40 60 Q 130 30 180 100" fill="none" stroke="url(#diffroute)" stroke-width="3" stroke-linecap="round" stroke-dasharray="220" stroke-dashoffset="0">
                <animate attributeName="stroke-dashoffset" from="220" to="0" dur="2.4s" repeatCount="indefinite"/>
              </path>
              <path d="M50 160 Q 140 170 180 100" fill="none" stroke="url(#diffroute)" stroke-width="3" stroke-linecap="round" stroke-dasharray="180" stroke-dashoffset="0">
                <animate attributeName="stroke-dashoffset" from="180" to="0" dur="2.4s" begin=".6s" repeatCount="indefinite"/>
              </path>
              <path d="M320 50 Q 240 50 180 100" fill="none" stroke="url(#diffroute)" stroke-width="3" stroke-linecap="round" stroke-dasharray="170" stroke-dashoffset="0">
                <animate attributeName="stroke-dashoffset" from="170" to="0" dur="2.4s" begin="1.2s" repeatCount="indefinite"/>
              </path>
              <path d="M310 160 Q 240 150 180 100" fill="none" stroke="url(#diffroute)" stroke-width="3" stroke-linecap="round" stroke-dasharray="160" stroke-dashoffset="0">
                <animate attributeName="stroke-dashoffset" from="160" to="0" dur="2.4s" begin="1.8s" repeatCount="indefinite"/>
              </path>
              <!-- Houses -->
              <g fill="#fff" stroke="#0F172A" stroke-width="1.5" stroke-linejoin="round">
                <g transform="translate(40,60)"><path d="M-9 4 L-9 -2 L0 -10 L9 -2 L9 4 Z"/><rect x="-3" y="-2" width="6" height="6" fill="#F5B400"/></g>
                <g transform="translate(50,160)"><path d="M-9 4 L-9 -2 L0 -10 L9 -2 L9 4 Z"/><rect x="-3" y="-2" width="6" height="6" fill="#F5B400"/></g>
                <g transform="translate(320,50)"><path d="M-9 4 L-9 -2 L0 -10 L9 -2 L9 4 Z"/><rect x="-3" y="-2" width="6" height="6" fill="#F5B400"/></g>
                <g transform="translate(310,160)"><path d="M-9 4 L-9 -2 L0 -10 L9 -2 L9 4 Z"/><rect x="-3" y="-2" width="6" height="6" fill="#F5B400"/></g>
              </g>
              <!-- School at center -->
              <g transform="translate(180,100)">
                <circle r="22" fill="#0F172A"/>
                <path d="M-10 4 L-10 -2 L0 -10 L10 -2 L10 4 Z M-4 4 L-4 -2 L4 -2 L4 4 Z" fill="#F5B400" stroke="none"/>
                <rect x="-12" y="4" width="24" height="3" fill="#F5B400"/>
              </g>
            </svg>
          </div>
          <span class="diff-tag y">@L["Home_Diff_Card1_Tag"]</span>
          <h3 class="diff-card-title">@L["Home_Diff_Card1_Title"]</h3>
          <p class="diff-card-desc">@L["Home_Diff_Card1_Desc"]</p>
          <ul class="diff-list">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Diff_Card1_B1"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Diff_Card1_B2"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Diff_Card1_B3"]</li>
          </ul>
        </article>

        <!-- 2. Tap-to-start QR -->
        <article class="diff-card">
          <div class="diff-visual diff-visual-qr" aria-hidden="true">
            <!-- Stylized QR code -->
            <div class="qr-frame">
              <span class="qr-corner tl"></span>
              <span class="qr-corner tr"></span>
              <span class="qr-corner bl"></span>
              <span class="qr-corner br"></span>
              <svg class="qr-svg" viewBox="0 0 24 24" fill="#0F172A" aria-hidden="true">
                <rect x="0" y="0" width="7" height="7"/>
                <rect x="1.5" y="1.5" width="4" height="4" fill="#fff"/>
                <rect x="2.75" y="2.75" width="1.5" height="1.5" fill="#0F172A"/>
                <rect x="17" y="0" width="7" height="7"/>
                <rect x="18.5" y="1.5" width="4" height="4" fill="#fff"/>
                <rect x="19.75" y="2.75" width="1.5" height="1.5" fill="#0F172A"/>
                <rect x="0" y="17" width="7" height="7"/>
                <rect x="1.5" y="18.5" width="4" height="4" fill="#fff"/>
                <rect x="2.75" y="19.75" width="1.5" height="1.5" fill="#0F172A"/>
                <rect x="9" y="2" width="2" height="2"/>
                <rect x="12" y="2" width="2" height="2"/>
                <rect x="9" y="5" width="2" height="2"/>
                <rect x="14" y="5" width="2" height="2"/>
                <rect x="2" y="9" width="2" height="2"/>
                <rect x="5" y="9" width="2" height="2"/>
                <rect x="9" y="9" width="2" height="2"/>
                <rect x="12" y="9" width="2" height="2"/>
                <rect x="17" y="9" width="2" height="2"/>
                <rect x="20" y="9" width="2" height="2"/>
                <rect x="2" y="12" width="2" height="2"/>
                <rect x="6" y="12" width="2" height="2"/>
                <rect x="11" y="12" width="2" height="2"/>
                <rect x="14" y="12" width="2" height="2"/>
                <rect x="18" y="12" width="2" height="2"/>
                <rect x="21" y="12" width="2" height="2"/>
                <rect x="9" y="15" width="2" height="2"/>
                <rect x="14" y="15" width="2" height="2"/>
                <rect x="17" y="15" width="2" height="2"/>
                <rect x="20" y="15" width="2" height="2"/>
                <rect x="9" y="18" width="2" height="2"/>
                <rect x="12" y="18" width="2" height="2"/>
                <rect x="15" y="18" width="2" height="2"/>
                <rect x="18" y="18" width="2" height="2"/>
                <rect x="21" y="18" width="2" height="2"/>
                <rect x="9" y="21" width="2" height="2"/>
                <rect x="14" y="21" width="2" height="2"/>
                <rect x="17" y="21" width="2" height="2"/>
              </svg>
              <span class="qr-scanline"></span>
            </div>
            <!-- Resume toast -->
            <div class="qr-toast">
              <span class="qr-toast-ico">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <div>
                <strong>@L["Home_Diff_Card2_ToastTitle"]</strong>
                <span>@L["Home_Diff_Card2_ToastDesc"]</span>
              </div>
            </div>
          </div>
          <span class="diff-tag b">@L["Home_Diff_Card2_Tag"]</span>
          <h3 class="diff-card-title">@L["Home_Diff_Card2_Title"]</h3>
          <p class="diff-card-desc">@L["Home_Diff_Card2_Desc"]</p>
          <ul class="diff-list">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Diff_Card2_B1"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Diff_Card2_B2"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Diff_Card2_B3"]</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="section-eyebrow">@L["Home_StepsEyebrow"]</div>
      <h2 class="section-title">@L["Home_StepsTitle"]</h2>
      <p class="section-lead">@L["Home_StepsLead"]</p>

      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-title">@L["Home_Step1_Title"]</div>
          <div class="step-desc">@L["Home_Step1_Desc"]</div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-title">@L["Home_Step2_Title"]</div>
