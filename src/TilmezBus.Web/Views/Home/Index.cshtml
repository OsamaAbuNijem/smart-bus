  <section class="section audiences">
    <div class="section-inner">
      <div class="section-eyebrow">@L["Home_AudEyebrow"]</div>
      <h2 class="section-title">@L["Home_AudTitle"]</h2>
      <p class="section-lead">@L["Home_AudLead"]</p>

      <div class="aud-grid">
        <div class="aud">
          <div class="aud-tag">@L["Home_Aud1_Tag"]</div>
          <div class="aud-title">@L["Home_Aud1_Title"]</div>
          <div class="aud-desc">@L["Home_Aud1_Desc"]</div>
          <ul class="aud-list">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud1_Bullet1"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud1_Bullet2"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud1_Bullet3"]</li>
          </ul>
        </div>
        <div class="aud b">
          <div class="aud-tag">@L["Home_Aud2_Tag"]</div>
          <div class="aud-title">@L["Home_Aud2_Title"]</div>
          <div class="aud-desc">@L["Home_Aud2_Desc"]</div>
          <ul class="aud-list">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud2_Bullet1"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud2_Bullet2"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud2_Bullet3"]</li>
          </ul>
        </div>
        <div class="aud g">
          <div class="aud-tag">@L["Home_Aud3_Tag"]</div>
          <div class="aud-title">@L["Home_Aud3_Title"]</div>
          <div class="aud-desc">@L["Home_Aud3_Desc"]</div>
          <ul class="aud-list">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud3_Bullet1"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud3_Bullet2"]</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Aud3_Bullet3"]</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Request a demo ─────────────────────────────────── -->
  <section class="section request-section" id="request-demo">
    <div class="section-inner request-grid">
      <div class="request-copy">
        <div class="section-eyebrow" style="text-align:start;">@L["Home_Request_Eyebrow"]</div>
        <h2 class="section-title" style="text-align:start;">@L["Home_Request_Title"]</h2>
        <p class="section-lead" style="text-align:start;margin:0 0 24px;">@L["Home_Request_Lead"]</p>
        <ul class="request-list">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Request_Bullet1"]</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Request_Bullet2"]</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>@L["Home_Request_Bullet3"]</li>
        </ul>
      </div>

      <form class="request-form" method="post" action="/Home/RequestDemo">
        @Html.AntiForgeryToken()

        @{
          var demoResult  = TempData["DemoResult"]  as string;
          var demoMessage = TempData["DemoMessage"] as string;
        }
        @if (demoResult == "ok")
        {
          <div class="request-banner ok">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>@L["Home_Request_Success"]</span>
          </div>
        }
        else if (demoResult == "error")
        {
          <div class="request-banner err">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>@(demoMessage == "missing-fields" ? L["Home_Request_ErrMissing"].Value : L["Home_Request_ErrGeneric"].Value)</span>
          </div>
        }

        <div class="request-row">
          <label>
            <span class="request-label">@L["Home_Request_FieldSchool"]</span>
            <input type="text" name="schoolName" required maxlength="200" placeholder="@L["Home_Request_PHSchool"]"/>
          </label>
          <label>
            <span class="request-label">@L["Home_Request_FieldContact"]</span>
            <input type="text" name="contactName" required maxlength="200" placeholder="@L["Home_Request_PHContact"]"/>
          </label>
        </div>
        <div class="request-row">
          <label>
            <span class="request-label">@L["Home_Request_FieldEmail"]</span>
            <input type="email" name="email" required maxlength="256" placeholder="@L["Home_Request_PHEmail"]"/>
          </label>
          <label>
            <span class="request-label">@L["Home_Request_FieldPhone"] <em class="opt">@L["Home_Request_Optional"]</em></span>
            <input type="tel" name="phoneNumber" maxlength="40" placeholder="@L["Home_Request_PHPhone"]"/>
          </label>
        </div>
        <label class="request-fullrow">
          <span class="request-label">@L["Home_Request_FieldNotes"] <em class="opt">@L["Home_Request_Optional"]</em></span>
          <textarea name="notes" rows="3" maxlength="2000" placeholder="@L["Home_Request_PHNotes"]"></textarea>
        </label>

        <button type="submit" class="btn-primary request-submit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          <span>@L["Home_Request_Submit"]</span>
        </button>
        <div class="request-fineprint">@L["Home_Request_FinePrint"]</div>
      </form>
    </div>
  </section>

