@model TilmezBus.Web.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "تم إرسال الرابط";
    Layout = null;
    var _isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var _dir   = _isRtl ? "rtl" : "ltr";
    var _culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@_culture" dir="@_dir">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"]</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:linear-gradient(180deg,#FFFBEB 0%,#FFFFFF 60%,#F7FAFC 100%);color:#0F172A;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;}
.card{width:100%;max-width:460px;background:#fff;border:1px solid #E5E7EB;border-radius:18px;padding:32px;box-shadow:0 10px 40px rgba(15,23,42,.06);text-align:center;}
.brand{font-weight:800;font-size:22px;letter-spacing:-0.3px;margin-bottom:18px;}
.brand .dot{color:#F5B400;}
.icon{width:64px;height:64px;border-radius:50%;background:#FEF3C7;color:#92400E;margin:0 auto 14px;display:flex;align-items:center;justify-content:center;font-size:28px;}
h1{font-size:20px;font-weight:800;margin-bottom:8px;letter-spacing:-0.3px;}
p{color:#475569;font-size:14px;line-height:1.65;margin-bottom:12px;}
.email-bubble{display:inline-block;background:#F8FAFC;border:1px solid #E2E8F0;padding:6px 12px;border-radius:8px;font-weight:600;color:#0F172A;font-size:13px;direction:ltr;}
a.btn{display:inline-block;margin-top:18px;background:#0F172A;color:#fff;text-decoration:none;padding:10px 18px;border-radius:10px;font-weight:700;font-size:13px;}
a.btn:hover{background:#1E293B;}
</style>
</head>
<body>
  <div class="card">
    <div class="brand">Tilmez<span class="dot">Bus</span></div>
    <div class="icon">✉</div>
    <h1>@(_isRtl ? "تحقق من بريدك" : "Check your inbox")</h1>
    <p>
      @(_isRtl
        ? "إذا كان البريد الإلكتروني التالي مسجلًا في النظام، فقد أرسلنا رسالة تحتوي على رابط لإعادة تعيين كلمة المرور:"
        : "If the email below matches an account in our system, we've sent it a link to reset the password:")
    </p>
    <div class="email-bubble">@Model.Email</div>
    <p style="margin-top:16px">
      @(_isRtl
        ? "صلاحية الرابط ساعة واحدة. إذا لم تصلك الرسالة خلال بضع دقائق، تحقق من مجلد البريد المزعج."
        : "The link is valid for one hour. If you don't see the email, check your spam folder.")
    </p>
    <a class="btn" asp-action="Login">@(_isRtl ? "العودة لتسجيل الدخول" : "Back to login")</a>
  </div>
</body>
</html>
