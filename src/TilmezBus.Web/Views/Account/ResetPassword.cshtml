@model TilmezBus.Web.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
    Layout = null;
    var _isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var _dir   = _isRtl ? "rtl" : "ltr";
    var _culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@_culture" dir="@_dir">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"]</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:linear-gradient(180deg,#FFFBEB 0%,#FFFFFF 60%,#F7FAFC 100%);color:#0F172A;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;}
.card{width:100%;max-width:440px;background:#fff;border:1px solid #E5E7EB;border-radius:18px;padding:28px;box-shadow:0 10px 40px rgba(15,23,42,.06);}
.brand{font-weight:800;font-size:22px;letter-spacing:-0.3px;margin-bottom:6px;}
.brand .dot{color:#F5B400;}
h1{font-size:20px;font-weight:800;margin:14px 0 6px 0;letter-spacing:-0.3px;}
p.lead{color:#475569;font-size:14px;line-height:1.6;margin-bottom:18px;}
.email-bubble{display:inline-block;background:#F8FAFC;border:1px solid #E2E8F0;padding:5px 10px;border-radius:8px;font-weight:600;font-size:12px;color:#0F172A;direction:ltr;margin-bottom:14px;}
.field{margin-bottom:14px;}
.field label{display:block;font-size:13px;font-weight:700;margin-bottom:6px;}
.field input{width:100%;padding:11px 12px;border:1px solid #E2E8F0;border-radius:10px;font:inherit;color:inherit;background:#fff;outline:none;transition:border-color .15s, box-shadow .15s;}
.field input:focus{border-color:#F5B400;box-shadow:0 0 0 3px rgba(245,180,0,.18);}
.field-error{color:#B91C1C;font-size:12px;margin-top:4px;}
button.primary{width:100%;background:#F5B400;color:#0F172A;border:none;border-radius:12px;padding:12px 16px;font:inherit;font-weight:800;cursor:pointer;letter-spacing:-0.2px;}
button.primary:hover{filter:brightness(0.96);}
.error{background:#FEF2F2;border:1px solid #FECACA;color:#B91C1C;font-size:13px;padding:10px 12px;border-radius:10px;margin-bottom:14px;}
.foot{margin-top:18px;text-align:center;}
.foot a{color:#0F172A;text-decoration:none;font-weight:600;font-size:13px;}
.foot a:hover{text-decoration:underline;}
.req{color:#64748B;font-size:11.5px;margin-top:4px;}
</style>
</head>
<body>
  <div class="card">
    <div class="brand">Tilmez<span class="dot">Bus</span></div>
    <h1>@(_isRtl ? "اختر كلمة مرور جديدة" : "Choose a new password")</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Email))
    {
      <div class="email-bubble">@Model.Email</div>
    }
    <p class="lead">
      @(_isRtl
        ? "أدخل كلمة مرور قوية. الحد الأدنى 8 أحرف، تحتوي على حرف كبير ورقم."
        : "Pick a strong password. Minimum 8 characters, including one uppercase letter and one digit.")
    </p>

    @{ var topErr = ViewData.ModelState[string.Empty]?.Errors.FirstOrDefault()?.ErrorMessage; }
    @if (!string.IsNullOrWhiteSpace(topErr))
    {
      <div class="error">@topErr</div>
    }

    <form asp-action="ResetPassword" method="post" novalidate>
      @Html.AntiForgeryToken()
      <input asp-for="Email"  type="hidden" />
      <input asp-for="Token"  type="hidden" />

      <div class="field">
        <label asp-for="NewPassword">@(_isRtl ? "كلمة المرور الجديدة" : "New password")</label>
        <input asp-for="NewPassword" type="password" autocomplete="new-password" required minlength="8" />
        <span asp-validation-for="NewPassword" class="field-error"></span>
      </div>
      <div class="field">
        <label asp-for="ConfirmPassword">@(_isRtl ? "تأكيد كلمة المرور" : "Confirm password")</label>
        <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" required minlength="8" />
        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
      </div>

      <button type="submit" class="primary">
        @(_isRtl ? "حفظ كلمة المرور" : "Save password")
      </button>
    </form>

    <div class="foot">
      <a asp-action="Login">@(_isRtl ? "العودة لتسجيل الدخول" : "Back to login")</a>
    </div>
  </div>
</body>
</html>
