@using TilmezBus.Application.Common.Models
@using TilmezBus.Application.Features.Alerts.Queries.GetAllAlerts
@using TilmezBus.Domain.Enums
@model PagedResult<AlertDto>

@if (Model is null || !Model.Items.Any())
{
    <div class="u-empty-state">@L["Alert_None"]</div>
}
else
{
    foreach (var a in Model.Items)
    {
        var isOpen  = a.Status == AlertStatus.Pending;
        var sevBg   = a.Severity == AlertSeverity.Urgent ? "#FEF2F2" : "#EFF6FF";
        <div class="alert-item @(isOpen ? "" : "resolved")">
            <div class="alert-icon" style="background:@sevBg;">!</div>
            <div class="u-flex-1">
                <div class="alert-title">@a.Title</div>
                <div class="alert-body">@a.Message</div>
                <div class="alert-time">@a.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                @if (isOpen)
                {
                    <div class="alert-actions">
                        <button class="alert-btn danger"    onclick="alerts.resolve('@a.Id')">@L["Alert_Resolve"]</button>
                        <button class="alert-btn secondary" onclick="alerts.ignore('@a.Id')">@L["Alert_Ignore"]</button>
                    </div>
                }
            </div>
        </div>
    }
}

<div class="u-hidden"
     data-header="@L["Alert_Count", Model?.TotalCount ?? 0]"
     data-total-pages="@(Model?.TotalPages ?? 1)"
     data-page="@(Model?.PageNumber ?? 1)"></div>
