@using TilmezBus.Application.Common.Models
@using TilmezBus.Application.Features.Students.Queries.GetAllStudents
@model PagedResult<StudentDto>

@if (Model is null || !Model.Items.Any())
{
    <tr><td colspan="8" class="u-empty-state">@L["Student_None"]</td></tr>
}
else
{
    var baseIndex = ((Model.PageNumber - 1) * Model.PageSize);
    var rowNum = 0;
    var _isAr = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    foreach (var s in Model.Items)
    {
        rowNum++;
        // Show the Arabic name in Arabic locale; English locale shows FullNameEn
        // with a graceful fallback to FullName when no English name is on file.
        var displayName = _isAr
            ? (string.IsNullOrWhiteSpace(s.FullName) ? (s.FullNameEn ?? string.Empty) : s.FullName)
            : (string.IsNullOrWhiteSpace(s.FullNameEn) ? s.FullName : s.FullNameEn!);
        <tr>
            <td class="u-text-muted u-text-sm">@(baseIndex + rowNum)</td>
            <td><div class="td-name">@displayName</div></td>
            <td dir="ltr" style="text-align:start;">
              <div class="td-sub">@(string.IsNullOrEmpty(s.NationalNumber) ? "—" : s.NationalNumber)</div>
            </td>
            <td><div class="td-sub">@s.ParentName</div></td>
            <td dir="ltr" style="text-align:start;"><div class="td-sub">@s.ParentPhone</div></td>
            <td>
                @if (s.Latitude.HasValue && s.Longitude.HasValue)
                {
                    // Render the coordinates LTR so "(31.95, 35.93)" doesn't
                    // flip in Arabic locale, and link to Google Maps for a
                    // one-click verification of the home pin the parent saved.
                    var lat = s.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                    var lng = s.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                    <a class="td-sub" dir="ltr" style="text-align:start; display:inline-flex; align-items:center; gap:4px;"
                       href="https://www.google.com/maps/search/?api=1&query=@lat,@lng"
                       target="_blank" rel="noopener"
                       aria-label="@string.Format(L["Student_LocationAriaOpen"].Value, displayName)">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#E11D48" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                        <span>@lat.Substring(0, Math.Min(7, lat.Length)), @lng.Substring(0, Math.Min(7, lng.Length))</span>
                    </a>
                }
                else
                {
                    <div class="td-sub">—</div>
                }
            </td>
            <td><div class="td-sub">@s.CreatedAt.ToString("dd MMM yyyy")</div></td>
            <td>
                <div class="tbl-actions">
                    <button class="tbl-btn tbl-qr"
                            aria-label="@string.Format(L["Student_AriaQr"].Value, displayName)"
                            title="@L["Student_AriaQr", displayName]"
                            onclick="students.openQr('@s.Id', '@displayName')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" focusable="false"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3h-3zM20 14v3M14 20h3M20 20v.01"/></svg>
                    </button>
                    <button class="tbl-btn tbl-edit"
                            aria-label="@string.Format(L["Student_AriaEdit"].Value, displayName)"
                            onclick="students.openForm('@s.Id')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
                    </button>
                    <button class="tbl-btn tbl-del"
                            aria-label="@string.Format(L["Student_AriaDelete"].Value, displayName)"
                            onclick="students.askDelete(this)"
                            data-id="@s.Id" data-name="@displayName" data-type="@L["Student_TypeLabel"]">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" focusable="false"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                </div>
            </td>
        </tr>
    }
}

<tr class="u-hidden">
    <td data-pager-info="@L["Student_PagerInfo", Model?.Items.Count() ?? 0, Model?.TotalCount ?? 0, Model?.PageNumber ?? 1, Model?.TotalPages ?? 1]"
        data-total-pages="@(Model?.TotalPages ?? 1)"
        data-total-count="@(Model?.TotalCount ?? 0)"
        data-page="@(Model?.PageNumber ?? 1)"></td>
</tr>
