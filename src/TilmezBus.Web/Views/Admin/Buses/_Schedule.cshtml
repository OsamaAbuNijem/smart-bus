@model TilmezBus.Web.Models.BusScheduleViewModel
@{
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var errors = ViewData.ModelState;

    string DriverLabel(TilmezBus.Application.Features.Drivers.Queries.GetAllDrivers.DriverDto d)
        => !isRtl && !string.IsNullOrEmpty(d.FullNameEn) ? d.FullNameEn : d.FullName;

    string StudentLabel(TilmezBus.Application.Features.Students.Queries.GetAllStudents.StudentDto s)
        => !isRtl && !string.IsNullOrEmpty(s.FullNameEn) ? s.FullNameEn! : s.FullName;

    byte days = Model.Input.RepeatDays;
    bool DayOn(byte mask) => (days & mask) == mask;

    // Bitmask: Sun=1, Mon=2, Tue=4, Wed=8, Thu=16, Fri=32, Sat=64
    var dayDefs = new[]
    {
        (Mask: (byte)1,  Label: L["Day_Sun"].Value),
        (Mask: (byte)2,  Label: L["Day_Mon"].Value),
        (Mask: (byte)4,  Label: L["Day_Tue"].Value),
        (Mask: (byte)8,  Label: L["Day_Wed"].Value),
        (Mask: (byte)16, Label: L["Day_Thu"].Value),
        (Mask: (byte)32, Label: L["Day_Fri"].Value),
        (Mask: (byte)64, Label: L["Day_Sat"].Value)
    };
}

<form id="bus-schedule-form"
      data-id="@Model.BusId"
      onsubmit="event.preventDefault(); buses.submitSchedule(this);">

  <div class="modal-header">
    <div class="modal-header-title">@L["BusSchedule_Title"] — @Model.BusPlateNumber</div>
    <button type="button" class="modal-close-btn" onclick="SB.closeModal('modal-bus-schedule')">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="modal-body">
    @if (errors.ErrorCount > 0)
    {
        <div class="form-server-err" style="display:block; margin-bottom:14px;">
            @foreach (var state in errors)
            {
                foreach (var err in state.Value.Errors)
                {
                    <div>@(string.IsNullOrEmpty(state.Key) ? "" : state.Key + ": ")@err.ErrorMessage</div>
                }
            }
        </div>
    }

    <div class="schedule-section">
      <div class="schedule-section-title">@L["BusSchedule_Morning"]</div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["BusSchedule_Time"]</label>
          <input type="time" name="MorningTime" class="form-input" dir="ltr" value="@Model.Input.MorningTime"/>
        </div>
        <div class="form-group">
          <label class="form-label">@L["Bus_Driver"]</label>
          <select name="MorningDriverId" class="form-input">
            <option value="">@L["Bus_NoneSelected"]</option>
            @foreach (var d in Model.Drivers)
            {
                <option value="@d.Id" selected="@(Model.Input.MorningDriverId == d.Id)">@DriverLabel(d)</option>
            }
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">@L["Bus_Assistant"]</label>
          <select name="MorningAssistantId" class="form-input">
            <option value="">@L["Bus_NoneSelected"]</option>
            @foreach (var a in Model.Assistants)
            {
                <option value="@a.Id" selected="@(Model.Input.MorningAssistantId == a.Id)">@DriverLabel(a)</option>
            }
          </select>
        </div>
      </div>
    </div>

    <div class="schedule-section">
      <div class="schedule-section-title">@L["BusSchedule_Return"]</div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["BusSchedule_Time"]</label>
          <input type="time" name="ReturnTime" class="form-input" dir="ltr" value="@Model.Input.ReturnTime"/>
        </div>
        <div class="form-group">
          <label class="form-label">@L["Bus_Driver"]</label>
          <select name="ReturnDriverId" class="form-input">
            <option value="">@L["Bus_NoneSelected"]</option>
            @foreach (var d in Model.Drivers)
            {
                <option value="@d.Id" selected="@(Model.Input.ReturnDriverId == d.Id)">@DriverLabel(d)</option>
            }
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">@L["Bus_Assistant"]</label>
          <select name="ReturnAssistantId" class="form-input">
            <option value="">@L["Bus_NoneSelected"]</option>
            @foreach (var a in Model.Assistants)
            {
                <option value="@a.Id" selected="@(Model.Input.ReturnAssistantId == a.Id)">@DriverLabel(a)</option>
            }
          </select>
        </div>
      </div>
    </div>

    <div class="schedule-section">
      <div class="schedule-section-title">@L["BusSchedule_Days"]</div>
      <input type="hidden" name="RepeatDays" id="bs-repeat-days" value="@Model.Input.RepeatDays"/>
      <div class="schedule-days">
        @foreach (var (mask, label) in dayDefs)
        {
            <label class="schedule-day @(DayOn(mask) ? "active" : "")" data-mask="@mask">
              <input type="checkbox" class="schedule-day-cb" data-mask="@mask" @(DayOn(mask) ? "checked" : "") onchange="buses.toggleScheduleDay(this)"/>
              <span>@label</span>
            </label>
        }
      </div>
    </div>

    <div class="schedule-section">
      <div class="schedule-section-title">@L["BusSchedule_Students"]</div>
      <input type="text" class="form-input" id="bs-student-search"
             placeholder="@L["SearchShort"]"
             autocomplete="off" oninput="buses.filterScheduleStudents(this.value)"/>
      <div id="bs-students-list" class="bus-students-list">
        @foreach (var s in Model.Students)
        {
            var checked_ = Model.SelectedStudentIds.Contains(s.Id);
            <label class="bus-student-row" data-name="@StudentLabel(s).ToLowerInvariant()" data-area="@(s.HomeArea ?? "").ToLowerInvariant()">
              <input type="checkbox" name="StudentIds" value="@s.Id" @(checked_ ? "checked" : "")/>
              <div class="bus-student-info">
                <div class="bus-student-name">@StudentLabel(s)</div>
                <div class="bus-student-meta">@L["Std_Grade" + s.Grade]@(!string.IsNullOrEmpty(s.HomeArea) ? " — " + s.HomeArea : "")</div>
              </div>
            </label>
        }
      </div>
      <div class="bus-student-counter">
        <span id="bs-selected-count">@Model.SelectedStudentIds.Count</span> @L["BusSchedule_StudentsSelected"]
      </div>
    </div>

  </div>

  <div class="modal-footer">
    <button type="submit" class="btn-primary">@L["Bus_SaveBtn"]</button>
    <button type="button" class="btn-secondary" onclick="SB.closeModal('modal-bus-schedule')">@L["Del_Cancel"]</button>
  </div>
</form>
