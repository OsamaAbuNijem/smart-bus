@model AdminPageViewModel
@{
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    string NavClass(string page) => Model.ActivePage == page ? "nav-item active" : "nav-item";
}

<div class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark">
      <div class="logo-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round">
          <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/>
          <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      </div>
      <div class="logo-text">
        <div class="logo-name">@(Model.SchoolName.Length > 0 ? Model.SchoolName : (isRtl ? "مدرسة باص التلميذ" : "TilmezBus School"))</div>
        <div class="logo-sub">@(string.IsNullOrWhiteSpace(Model.SchoolCity) ? (isRtl ? "لوحة الإدارة" : "Admin Panel") : Model.SchoolCity)</div>
      </div>
    </div>
  </div>

  <div class="sidebar-nav">
    <div class="nav-section">@L["Nav_Main"]</div>

    <a class="@NavClass("dashboard")" href="/Dashboard">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
      </svg>
      <span class="nav-label">@L["Nav_Dashboard"]</span>
    </a>

    <a class="@NavClass("trips")" href="/Trips">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/>
        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span class="nav-label">@L["Nav_Trips"]</span>
    </a>

    <div class="nav-section">@L["Nav_Mgmt"]</div>

    <a class="@NavClass("students")" href="/Students">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span class="nav-label">@L["Nav_Students"]</span>
    </a>

    <a class="@NavClass("drivers")" href="/Drivers">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
      </svg>
      <span class="nav-label">@L["Nav_Drivers"]</span>
    </a>

    <a class="@NavClass("buses")" href="/Buses">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <rect x="1" y="3" width="15" height="13" rx="2"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
      </svg>
      <span class="nav-label">@L["Nav_Buses"]</span>
    </a>

  </div>

  @{
    string? sbPlanLabel = Model.SubscriptionType switch
    {
        TilmezBus.Domain.Enums.SubscriptionType.Trial    => L["SA_Sub_Type_Trial"].Value,
        TilmezBus.Domain.Enums.SubscriptionType.Basic    => L["SA_Sub_Type_Basic"].Value,
        TilmezBus.Domain.Enums.SubscriptionType.Standard => L["SA_Sub_Type_Standard"].Value,
        TilmezBus.Domain.Enums.SubscriptionType.Premium  => L["SA_Sub_Type_Premium"].Value,
        _ => null
    };
    var sbToday = DateTime.UtcNow.Date;
    string sbStatusKey;
    // Treat IsActive=false the same as a past expiration — both show as
    // "Expired" to the school admin. The internal "Disabled" state was
    // visually distinct but operationally identical (the plan isn't
    // serving the school) and just made the chip ambiguous.
    if (Model.SubscriptionType is null)                                  sbStatusKey = "Admin_Settings_Plan_None";
    else if (Model.SubscriptionIsActive == false)                        sbStatusKey = "Admin_Settings_Plan_Expired";
    else if (Model.SubscriptionActivationDate?.Date > sbToday)           sbStatusKey = "Admin_Settings_Plan_Future";
    else if (Model.SubscriptionExpirationDate?.Date < sbToday)           sbStatusKey = "Admin_Settings_Plan_Expired";
    else                                                                  sbStatusKey = "Admin_Settings_Plan_Live";
    string sbStatusClass = "plan-status-" + sbStatusKey.Substring("Admin_Settings_Plan_".Length).ToLower();
    string sbFmt(DateTime? d) => d?.ToString("d MMM yyyy", System.Globalization.CultureInfo.CurrentUICulture) ?? "—";
  }
  <div class="sidebar-plan">
    <div class="sidebar-plan-head">
      <span class="sidebar-plan-label">@L["Admin_Settings_Plan_Current"]</span>
      <span class="sidebar-plan-status @sbStatusClass">@L[sbStatusKey]</span>
    </div>
    <div class="sidebar-plan-name">@(sbPlanLabel ?? L["Admin_Settings_Plan_None"].Value)</div>
    @if (Model.SubscriptionExpirationDate.HasValue)
    {
      <div class="sidebar-plan-meta">
        @L["Admin_Settings_Plan_To"] <strong>@sbFmt(Model.SubscriptionExpirationDate)</strong>
      </div>
    }
    @if (Model.SubscriptionMaxStudents.HasValue || Model.SubscriptionMaxBuses.HasValue || Model.SubscriptionPrice.HasValue)
    {
      <div class="sidebar-plan-stats">
        @if (Model.SubscriptionMaxStudents.HasValue)
        {
          <div class="sidebar-plan-stat">
            <span class="sidebar-plan-stat-num">@Model.SubscriptionMaxStudents.Value</span>
            <span class="sidebar-plan-stat-lbl">@L["Admin_Settings_Plan_MaxStudents"]</span>
          </div>
        }
        @if (Model.SubscriptionMaxBuses.HasValue)
        {
          <div class="sidebar-plan-stat">
            <span class="sidebar-plan-stat-num">@Model.SubscriptionMaxBuses.Value</span>
            <span class="sidebar-plan-stat-lbl">@L["Admin_Settings_Plan_MaxBuses"]</span>
          </div>
        }
        @if (Model.SubscriptionPrice.HasValue)
        {
          <div class="sidebar-plan-stat">
            <span class="sidebar-plan-stat-num">@Model.SubscriptionPrice.Value.ToString("0.##")</span>
            <span class="sidebar-plan-stat-lbl">@L["Admin_Settings_Plan_Currency"]</span>
          </div>
        }
      </div>
    }
  </div>

</div>
