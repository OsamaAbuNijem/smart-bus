@model AdminPageViewModel
@{
    var isRtl         = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var toggleCulture = isRtl ? "en" : "ar";
    var returnUrl     = Context.Request.Path + Context.Request.QueryString;
}

<div class="topbar">
  <div style="display:flex;align-items:center;min-width:0;flex:1;">
    <button type="button" class="tb-menu" data-action="open-sidebar" aria-label="@L["Nav_Menu"]" aria-expanded="false">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="topbar-title">@Model.PageTitle</div>
  </div>
  <div class="topbar-right">
    <div class="date-chip" id="date-chip"></div>
    <a class="lang-btn" href="/Language/Set?culture=@toggleCulture&returnUrl=@Uri.EscapeDataString(returnUrl)" title="@L["LangName"]">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      <span>@L["SwitchLang"]</span>
    </a>
    <a class="tb-btn" href="/Alerts" title="@L["Nav_Alerts"]">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      </svg>
      <div class="tb-badge"></div>
    </a>
    <button type="button" class="tb-btn" data-action="open-change-password" title="@L["Admin_ChangePassword"]" aria-label="@L["Admin_ChangePassword"]">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </button>
    <form asp-controller="Account" asp-action="Logout" method="post" class="tb-logout-form">
      @Html.AntiForgeryToken()
      <button type="submit" class="tb-btn tb-btn-logout" title="@L["Logout"]" aria-label="@L["Logout"]">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      </button>
    </form>
  </div>
</div>
