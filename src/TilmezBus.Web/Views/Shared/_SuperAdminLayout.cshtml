          <span class="prefix" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </span>
          <input type="password" id="cp-confirm" placeholder="••••••••" autocomplete="new-password"/>
        </div>
        <span class="form-err" id="err-cp-confirm">@L["SA_ChangePwd_MismatchErr"]</span>
