     data-title-create="@L["SA_Sub_Page_AddTitle"]"
     data-title-edit="@L["SA_Sub_Page_EditTitle"]">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-header-title" id="sub-modal-title">@L["SA_Sub_Page_AddTitle"]</div>
