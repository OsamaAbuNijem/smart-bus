      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_ActivationDate"]</label>
          <input type="date" id="sub-activation" class="form-control"/>
        </div>
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_ExpirationDate"]</label>
          <input type="date" id="sub-expiration" class="form-control"/>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Page_MaxStudents"]</label>
          <input type="number" id="sub-max-students" class="form-control" min="0"/>
