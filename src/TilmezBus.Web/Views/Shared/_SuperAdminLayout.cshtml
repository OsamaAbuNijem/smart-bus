        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Page_MaxBuses"]</label>
          <input type="number" id="sub-max-buses" class="form-control" min="0"/>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Price"]</label>
          <div class="form-input-group" dir="ltr">
            <input type="number" id="sub-price" placeholder="0" min="0" step="0.01"/>
            <span class="suffix">@L["SA_Currency_JD"]</span>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Remaining"]</label>
          <div class="form-input-group is-readonly" dir="ltr" title="@L["SA_Sub_Remaining_AutoHint"]">
            <input type="number" id="sub-remaining" placeholder="0" min="0" step="0.01" readonly/>
            <span class="suffix">@L["SA_Currency_JD"]</span>
          </div>
          <span class="form-hint">@L["SA_Sub_Remaining_AutoHint"]</span>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Paid"]</label>
          <select id="sub-paid" class="form-control is-readonly" disabled title="@L["SA_Sub_Paid_AutoHint"]">
            <option value="0">@L["SA_Sub_Paid_No"]</option>
            <option value="1">@L["SA_Sub_Paid_Partial"]</option>
            <option value="2">@L["SA_Sub_Paid_Yes"]</option>
          </select>
          <span class="form-hint">@L["SA_Sub_Paid_AutoHint"]</span>
        </div>
        <div class="form-group"></div>
      </div>
      @* Payments section — visible only when editing an existing sub. Lists
         every recorded payment instalment and offers an inline add form. *@
      <div id="sub-payments-section" class="u-hidden">
        <div class="form-row full">
          <div class="form-group u-mt-12">
            <div class="sub-section-title">@L["SA_Sub_Payments_Title"]</div>
            <div class="sub-section-hint">@L["SA_Sub_Payments_Hint"]</div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">@L["SA_Sub_Payments_Date"]</label>
            <input type="date" id="sub-pay-date" class="form-control"/>
