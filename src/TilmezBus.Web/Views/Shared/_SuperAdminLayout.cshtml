          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">@L["SA_Sub_Payments_Method"]</label>
            <select id="sub-pay-method" class="form-control">
              <option value="0">@L["SA_Pay_Method_Cash"]</option>
              <option value="1">@L["SA_Pay_Method_Transfer"]</option>
              <option value="2">@L["SA_Pay_Method_Cheque"]</option>
            </select>
          </div>
          <div class="form-group u-flex u-items-end">
            <button type="button" class="btn-pu" id="sub-pay-add-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              @L["SA_Sub_Payments_Add"]
            </button>
          </div>
        </div>
        <div id="sub-pay-error" class="modal-form-err u-hidden"></div>
        <div class="card-table-wrap u-mt-12">
          <table class="table">
            <thead><tr>
              <th>@L["SA_Sub_Payments_Date"]</th>
              <th>@L["SA_Sub_Payments_Amount"]</th>
              <th>@L["SA_Sub_Payments_Method"]</th>
            </tr></thead>
            <tbody id="sub-pay-tbody">
              <tr><td colspan="3" class="td-empty">@L["SA_Sub_Payments_Empty"]</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div id="sub-error" class="modal-form-err u-hidden"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" id="sub-save-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        @L["SA_School_Save"]
      </button>
      <button class="btn-secondary" id="sub-cancel-btn">@L["SA_School_Cancel"]</button>
    </div>
  </div>
</div>
