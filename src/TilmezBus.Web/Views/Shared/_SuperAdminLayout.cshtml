<script>
  // Wire the shared subscription modal on every SA page (the modal lives in
  // the layout so the Schools drawer can also open it). Subscriptions page
  // additionally calls subscriptions.init() to wire its grid + dropdown.
  document.addEventListener('DOMContentLoaded', async () => {
