          <div class="form-group">
            <label class="form-label">@L["SA_Sub_Payments_Amount"]</label>
            <div class="form-input-group" dir="ltr">
              <input type="number" id="sub-pay-amount" placeholder="0" min="0" step="0.01"/>
              <span class="suffix">@L["SA_Currency_JD"]</span>
