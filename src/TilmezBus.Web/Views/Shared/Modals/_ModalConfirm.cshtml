<div class="modal-overlay" id="modal-confirm">
  <div class="modal-box xs">
    <div class="modal-header">
      <div class="modal-header-title" id="confirm-title">@L["Confirm_Title"]</div>
      <button class="modal-close-btn" data-action="modal-close" data-target="modal-confirm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body center">
      <div class="modal-ico-circle-info" id="confirm-icon-wrap">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <div class="modal-heading-line" id="confirm-heading">@L["Confirm_Heading"]</div>
      <div class="modal-body-line" id="confirm-body"></div>
    </div>
    <div class="modal-footer center">
      <button class="btn-primary" id="confirm-btn">@L["Confirm_Confirm"]</button>
      <button class="btn-secondary" data-action="modal-close" data-target="modal-confirm">@L["Confirm_Cancel"]</button>
    </div>
  </div>
</div>
