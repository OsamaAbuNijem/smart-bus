@{
    ViewData["Title"] = "المدارس";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="page active" id="sa-page-schools">

  <div class="filter-bar">
    <button class="filter-btn active" onclick="filterSchools('all',this)">الكل</button>
    <button class="filter-btn" onclick="filterSchools('active',this)">نشطة</button>
    <button class="filter-btn" onclick="filterSchools('inactive',this)">موقوفة</button>
    <button class="filter-btn" onclick="filterSchools('premium',this)">Premium</button>
    <button class="add-btn" onclick="openSchoolModal()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      إضافة مدرسة
    </button>
  </div>

  <!-- Bulk action bar (hidden until rows selected) -->
  <div class="bulk-bar" id="bulk-bar" style="display:none;">
    <span class="bulk-count" id="bulk-count-label">0 مدارس محددة</span>
    <button class="bulk-btn del" onclick="bulkDelete()">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
      حذف المحددة
    </button>
    <button class="bulk-btn" onclick="clearSelection()">إلغاء التحديد</button>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">قائمة المدارس</div>
        <div class="card-sub" id="schools-pager-info">جاري التحميل...</div>
      </div>
      <div style="font-size:22px;font-weight:800;color:var(--pu);" id="schools-total">—</div>
    </div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr>
            <th style="width:36px;"><input type="checkbox" class="cb" id="chk-all" onchange="toggleSelectAll(this.checked)" title="تحديد الكل"/></th>
            <th>المدرسة</th>
            <th>المدينة</th>
            <th>المدير</th>
            <th>تاريخ الإنشاء</th>
            <th>إجراءات</th>
          </tr>
        </thead>
        <tbody id="schools-tbody">
          <tr class="skel-row"><td></td><td><div class="skel" style="height:16px;width:150px;"></div></td><td><div class="skel" style="height:14px;width:80px;"></div></td><td><div class="skel" style="height:14px;width:120px;"></div></td><td><div class="skel" style="height:14px;width:90px;"></div></td><td></td></tr>
          <tr class="skel-row"><td></td><td><div class="skel" style="height:16px;width:130px;"></div></td><td><div class="skel" style="height:14px;width:70px;"></div></td><td><div class="skel" style="height:14px;width:130px;"></div></td><td><div class="skel" style="height:14px;width:90px;"></div></td><td></td></tr>
          <tr class="skel-row"><td></td><td><div class="skel" style="height:16px;width:165px;"></div></td><td><div class="skel" style="height:14px;width:85px;"></div></td><td><div class="skel" style="height:14px;width:115px;"></div></td><td><div class="skel" style="height:14px;width:90px;"></div></td><td></td></tr>
        </tbody>
      </table>
    </div>
    <div class="pager">
      <span class="pager-info" id="schools-pager-text"></span>
      <button class="pager-btn" id="schools-prev" onclick="loadSchools(schoolsPage-1)" disabled>السابق</button>
      <span class="pager-num" id="schools-pager-num"></span>
      <button class="pager-btn" id="schools-next" onclick="loadSchools(schoolsPage+1)" disabled>التالي</button>
    </div>
  </div>
</div>

<script>
  // Schools page kickoff. The shared superadmin.js defines loadSchools /
  // filterSchools / openSchoolModal / bulkDelete etc.; we just trigger the
  // initial load + reveal the topbar search + CSV export controls (those
  // only make sense on this page).
  document.addEventListener('DOMContentLoaded', () => {
    const search = document.getElementById('topbar-search');
    const exp    = document.getElementById('btn-export');
    if (search) search.style.display = '';
    if (exp)    exp.style.display    = '';
    if (typeof loadSchools === 'function') loadSchools(1);
  });
</script>
