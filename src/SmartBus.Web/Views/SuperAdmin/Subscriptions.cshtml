@{
    ViewData["Title"] = "الاشتراكات";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="page active" id="sa-page-subscriptions">

  <div class="card" style="margin-bottom:16px;">
    <div class="card-body" style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
      <div style="flex:1;min-width:220px;">
        <div style="font-size:14px;font-weight:800;color:var(--text);">@L["SA_Sub_Page_Title"]</div>
        <div style="font-size:12px;color:var(--text3);margin-top:2px;">@L["SA_Sub_Page_Sub"]</div>
      </div>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <label class="form-label" style="margin:0;">@L["SA_Sub_Page_School"]</label>
        <select id="sub-school-select" class="form-control" style="min-width:240px;">
          <option value="">—</option>
        </select>
        <button type="button" class="btn-primary" id="sub-add-btn" disabled>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          @L["SA_Sub_Page_Add"]
        </button>
      </div>
    </div>
  </div>

  <div class="card">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr>
            <th>@L["SA_Sub_Type"]</th>
            <th>@L["SA_Sub_ActivationDate"]</th>
            <th>@L["SA_Sub_ExpirationDate"]</th>
            <th>@L["SA_Sub_Page_Status"]</th>
            <th>@L["SA_Sub_Page_MaxStudents"]</th>
            <th>@L["SA_Sub_Page_MaxBuses"]</th>
            <th>@L["SA_Sub_Price"]</th>
            <th>@L["SA_Sub_Paid"]</th>
            <th>@L["SA_Sub_Remaining"]</th>
            <th style="width:80px;text-align:end;">@L["SA_Sub_Page_Actions"]</th>
          </tr>
        </thead>
        <tbody id="sub-tbody">
          <tr><td colspan="10" style="text-align:center;color:var(--text3);padding:30px;">@L["SA_Sub_Page_PickSchool"]</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- MODAL: subscription create / edit -->
<div class="modal-overlay" id="modal-subscription"
     data-title-create="@L["SA_Sub_Page_AddTitle"]"
     data-title-edit="@L["SA_Sub_Page_EditTitle"]">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-header-title" id="sub-modal-title">@L["SA_Sub_Page_AddTitle"]</div>
      <button class="modal-close-btn" id="sub-close-btn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="sub-id"/>
      <input type="hidden" id="sub-target-school"/>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Type"]</label>
          <select id="sub-type" class="form-control">
            <option value="0">@L["SA_Sub_Type_Trial"]</option>
            <option value="1">@L["SA_Sub_Type_Basic"]</option>
            <option value="2">@L["SA_Sub_Type_Standard"]</option>
            <option value="3">@L["SA_Sub_Type_Premium"]</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Page_StatusActive"]</label>
          <select id="sub-active" class="form-control">
            <option value="true">@L["SA_Sub_Page_StatusActive_On"]</option>
            <option value="false">@L["SA_Sub_Page_StatusActive_Off"]</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_ActivationDate"]</label>
          <input type="date" id="sub-activation" class="form-control"/>
        </div>
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_ExpirationDate"]</label>
          <input type="date" id="sub-expiration" class="form-control"/>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Page_MaxStudents"]</label>
          <input type="number" id="sub-max-students" class="form-control" min="0"/>
        </div>
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Page_MaxBuses"]</label>
          <input type="number" id="sub-max-buses" class="form-control" min="0"/>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Price"]</label>
          <input type="number" id="sub-price" class="form-control" min="0" step="0.01"/>
        </div>
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Remaining"]</label>
          <input type="number" id="sub-remaining" class="form-control" min="0" step="0.01"/>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["SA_Sub_Paid"]</label>
          <select id="sub-paid" class="form-control">
            <option value="false">@L["SA_Sub_Paid_No"]</option>
            <option value="true">@L["SA_Sub_Paid_Yes"]</option>
          </select>
        </div>
        <div class="form-group"></div>
      </div>
      <div id="sub-error" style="display:none;margin-top:8px;font-size:12px;color:#B91C1C;"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" id="sub-save-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        @L["SA_School_Save"]
      </button>
      <button class="btn-secondary" id="sub-cancel-btn">@L["SA_School_Cancel"]</button>
    </div>
  </div>
</div>

@{
    // Strings the JS needs at runtime. Marshalled via data-attributes on a
    // hidden node so the in-page <script> stays culture-agnostic.
}
<div id="sub-strings"
     data-pick-school="@L["SA_Sub_Page_PickSchool"]"
     data-no-subs="@L["SA_Sub_Page_NoSubs"]"
     data-failed="Failed to load subscriptions. Try refreshing or signing in again."
     data-saving="…"
     data-saved="✓"
     data-paid-yes="@L["SA_Sub_Paid_Yes"]"
     data-paid-no="@L["SA_Sub_Paid_No"]"
     data-edit="@L["SA_Sub_Page_Edit"]"
     data-status-live="@L["SA_Sub_Page_Status_Live"]"
     data-status-expired="@L["SA_Sub_Page_Status_Expired"]"
     data-status-future="@L["SA_Sub_Page_Status_Future"]"
     data-status-off="@L["SA_Sub_Page_Status_Off"]"
     data-type-0="@L["SA_Sub_Type_Trial"]"
     data-type-1="@L["SA_Sub_Type_Basic"]"
     data-type-2="@L["SA_Sub_Type_Standard"]"
     data-type-3="@L["SA_Sub_Type_Premium"]"
     style="display:none;"></div>

<script>
(function () {
  'use strict';
  // Self-contained subscription module — does not depend on superadmin.js.
  // The proxy is mounted under /api-proxy and forwards to /api/v1/* on the API.

  const TYPE_NAMES = ['Trial', 'Basic', 'Standard', 'Premium'];
  const S = (function () {
    const root = document.getElementById('sub-strings');
    const d = root ? root.dataset : {};
    return {
      pickSchool:    d.pickSchool    || 'Pick a school.',
      noSubs:        d.noSubs        || 'No subscriptions yet.',
      failed:        d.failed        || 'Failed to load subscriptions.',
      paidYes:       d.paidYes       || 'Paid',
      paidNo:        d.paidNo        || 'Unpaid',
      edit:          d.edit          || 'Edit',
      statusLive:    d.statusLive    || 'Active',
      statusExpired: d.statusExpired || 'Expired',
      statusFuture:  d.statusFuture  || 'Future',
      statusOff:     d.statusOff     || 'Disabled',
      types: [d.type0 || 'Trial', d.type1 || 'Basic', d.type2 || 'Standard', d.type3 || 'Premium'],
    };
  })();

  const esc = (s) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

  function typeToNum(v) {
    if (typeof v === 'number') return v;
    const i = TYPE_NAMES.indexOf(String(v));
    return i >= 0 ? i : 0;
  }
  function typeLabel(v) { return S.types[typeToNum(v)] ?? String(v); }

  async function api(method, path, body) {
    const init = {
      method,
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
    };
    if (body !== undefined) {
      init.headers['Content-Type'] = 'application/json';
      init.body = JSON.stringify(body);
    }
    try {
      const res = await fetch('/api-proxy' + path, init);
      const text = await res.text();
      const json = text ? JSON.parse(text) : null;
      return { ok: res.ok, status: res.status, data: json };
    } catch (err) {
      return { ok: false, status: 0, data: { error: err && err.message } };
    }
  }

  function fmtDate(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '—';
    return d.getUTCFullYear() + '-' + String(d.getUTCMonth() + 1).padStart(2, '0') + '-' + String(d.getUTCDate()).padStart(2, '0');
  }
  function fmtMoney(v) {
    const n = Number(v);
    return Number.isFinite(n) ? n.toFixed(2) : '—';
  }
  function statusPill(s) {
    const now = new Date();
    const act = new Date(s.activationDate);
    const exp = new Date(s.expirationDate);
    let label, bg, color;
    if (!s.isActive)        { label = S.statusOff;     bg = '#F1F5F9'; color = '#475569'; }
    else if (exp < now)     { label = S.statusExpired; bg = '#FEF2F2'; color = '#B91C1C'; }
    else if (act > now)     { label = S.statusFuture;  bg = '#FFF7ED'; color = '#C2410C'; }
    else                    { label = S.statusLive;    bg = '#F0FDF4'; color = '#15803D'; }
    return `<span style="background:${bg};color:${color};padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;">${esc(label)}</span>`;
  }

  const tbody       = document.getElementById('sub-tbody');
  const sel         = document.getElementById('sub-school-select');
  const addBtn      = document.getElementById('sub-add-btn');
  const modal       = document.getElementById('modal-subscription');
  const errBox      = document.getElementById('sub-error');
  let currentSchool = null;
  let allSubs       = [];

  function setEmpty(html, color) {
    tbody.innerHTML = `<tr><td colspan="10" style="text-align:center;color:${color || 'var(--text3)'};padding:30px;">${esc(html)}</td></tr>`;
  }

  async function loadSchools() {
    const res = await api('GET', '/schools?pageNumber=1&pageSize=200');
    const schools = res.ok && res.data ? (res.data.items || []) : [];
    schools.sort((a, b) => (a.name || '').localeCompare(b.name || ''));
    const placeholderText = sel.querySelector('option[value=""]')?.textContent || '—';
    sel.innerHTML = `<option value="">${esc(placeholderText)}</option>` +
      schools.map(s => `<option value="${esc(s.id)}">${esc(s.name)}</option>`).join('');
  }

  async function loadSubsFor(schoolId) {
    currentSchool = schoolId || null;
    if (!currentSchool) {
      addBtn.disabled = true;
      setEmpty(S.pickSchool);
      return;
    }
    addBtn.disabled = false;
    setEmpty('…');
    const res = await api('GET', `/schools/${currentSchool}/subscriptions`);
    if (!res.ok) { setEmpty(S.failed, '#B91C1C'); return; }
    allSubs = Array.isArray(res.data) ? res.data : [];
    if (allSubs.length === 0) { setEmpty(S.noSubs); return; }

    tbody.innerHTML = allSubs.map(s => {
      const paidPill = s.isPaid
        ? `<span style="background:#F0FDF4;color:#15803D;padding:2px 8px;border-radius:8px;font-size:11px;font-weight:700;">${esc(S.paidYes)}</span>`
        : `<span style="background:#FEF2F2;color:#B91C1C;padding:2px 8px;border-radius:8px;font-size:11px;font-weight:700;">${esc(S.paidNo)}</span>`;
      return `
        <tr>
          <td style="font-weight:700;">${esc(typeLabel(s.subscriptionType))}</td>
          <td>${esc(fmtDate(s.activationDate))}</td>
          <td>${esc(fmtDate(s.expirationDate))}</td>
          <td>${statusPill(s)}</td>
          <td style="text-align:center;">${esc(s.maxStudents)}</td>
          <td style="text-align:center;">${esc(s.maxBuses)}</td>
          <td>${esc(fmtMoney(s.price))}</td>
          <td>${paidPill}</td>
          <td>${esc(fmtMoney(s.remainingAmount))}</td>
          <td style="text-align:end;">
            <button type="button" class="btn-secondary" data-sub-id="${esc(s.id)}" style="padding:5px 10px;font-size:12px;">${esc(S.edit)}</button>
          </td>
        </tr>`;
    }).join('');
  }

  function openModalEl()  { modal.classList.add('open'); errBox.style.display = 'none'; }
  function closeModalEl() { modal.classList.remove('open'); }

  function openCreate() {
    if (!currentSchool) return;
    document.getElementById('sub-id').value = '';
    document.getElementById('sub-target-school').value = currentSchool;
    document.getElementById('sub-modal-title').textContent = modal.dataset.titleCreate || 'New subscription';
    const today = new Date();
    const inOneYear = new Date(today.getFullYear() + 1, today.getMonth(), today.getDate());
    const iso = (d) => d.toISOString().slice(0, 10);
    document.getElementById('sub-activation').value   = iso(today);
    document.getElementById('sub-expiration').value   = iso(inOneYear);
    document.getElementById('sub-type').value         = '0';
    document.getElementById('sub-active').value       = 'true';
    document.getElementById('sub-max-students').value = '500';
    document.getElementById('sub-max-buses').value    = '20';
    document.getElementById('sub-price').value        = '0';
    document.getElementById('sub-paid').value         = 'false';
    document.getElementById('sub-remaining').value    = '0';
    openModalEl();
  }

  function openEdit(s) {
    document.getElementById('sub-id').value = s.id;
    document.getElementById('sub-target-school').value = s.schoolId;
    document.getElementById('sub-modal-title').textContent = modal.dataset.titleEdit || 'Edit subscription';
    document.getElementById('sub-activation').value   = (s.activationDate || '').slice(0, 10);
    document.getElementById('sub-expiration').value   = (s.expirationDate || '').slice(0, 10);
    document.getElementById('sub-type').value         = String(typeToNum(s.subscriptionType));
    document.getElementById('sub-active').value       = String(!!s.isActive);
    document.getElementById('sub-max-students').value = s.maxStudents ?? 0;
    document.getElementById('sub-max-buses').value    = s.maxBuses ?? 0;
    document.getElementById('sub-price').value        = s.price ?? 0;
    document.getElementById('sub-paid').value         = String(!!s.isPaid);
    document.getElementById('sub-remaining').value    = s.remainingAmount ?? 0;
    openModalEl();
  }

  async function save() {
    errBox.style.display = 'none';
    const id = document.getElementById('sub-id').value;
    const schoolId = document.getElementById('sub-target-school').value;
    const actIso = document.getElementById('sub-activation').value;
    const expIso = document.getElementById('sub-expiration').value;
    if (!schoolId || !actIso || !expIso) {
      errBox.textContent = 'School and dates are required.';
      errBox.style.display = '';
      return;
    }
    const body = {
      subscriptionType: parseInt(document.getElementById('sub-type').value, 10) || 0,
      maxStudents:      parseInt(document.getElementById('sub-max-students').value, 10) || 0,
      maxBuses:         parseInt(document.getElementById('sub-max-buses').value, 10) || 0,
      activationDate:   new Date(actIso + 'T00:00:00Z').toISOString(),
      expirationDate:   new Date(expIso + 'T23:59:59Z').toISOString(),
      isActive:         document.getElementById('sub-active').value === 'true',
      price:            parseFloat(document.getElementById('sub-price').value) || 0,
      isPaid:           document.getElementById('sub-paid').value === 'true',
      remainingAmount:  parseFloat(document.getElementById('sub-remaining').value) || 0,
    };
    const saveBtn = document.getElementById('sub-save-btn');
    saveBtn.disabled = true;
    try {
      const res = id
        ? await api('PUT',  '/subscriptions/' + id, body)
        : await api('POST', '/schools/' + schoolId + '/subscriptions', body);
      if (!res.ok) {
        errBox.textContent = (res.data && res.data.error) ? res.data.error : ('HTTP ' + res.status);
        errBox.style.display = '';
        return;
      }
      closeModalEl();
      await loadSubsFor(schoolId);
    } finally {
      saveBtn.disabled = false;
    }
  }

  // Wiring
  sel.addEventListener('change', () => loadSubsFor(sel.value));
  addBtn.addEventListener('click', openCreate);
  document.getElementById('sub-close-btn').addEventListener('click', closeModalEl);
  document.getElementById('sub-cancel-btn').addEventListener('click', closeModalEl);
  document.getElementById('sub-save-btn').addEventListener('click', save);
  tbody.addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-sub-id]');
    if (!btn) return;
    const found = allSubs.find(s => s.id === btn.dataset.subId);
    if (found) openEdit(found);
  });

  loadSchools();
})();
</script>
