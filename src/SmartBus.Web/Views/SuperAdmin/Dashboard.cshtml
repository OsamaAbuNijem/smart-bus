@{
    ViewData["Title"] = "لوحة التحكم العامة";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<!-- ══ OVERVIEW PAGE ══ -->
<div class="page active" id="sa-page-overview">

  <div class="welcome-banner">
    <div class="wb-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <div class="wb-text">
      <div class="wb-title">مرحباً، المشرف العام 👋</div>
      <div class="wb-sub">إدارة كاملة لجميع المدارس المشتركة في منصة SmartBus</div>
    </div>
    <div style="font-size:12px;color:rgba(255,255,255,.4);flex-shrink:0;" id="sa-date-chip"></div>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon" style="background:#F5F3FF;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <div class="stat-num" id="stat-total-schools">—</div>
      <div class="stat-label">إجمالي المدارس</div>
      <div class="stat-change up" id="stat-active-schools">— نشطة</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#F0FDF4;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="stat-num" id="stat-premium">—</div>
      <div class="stat-label">اشتراك Premium</div>
      <div class="stat-change up">خطة مميزة</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#EFF6FF;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </div>
      <div class="stat-num" id="stat-buses">—</div>
      <div class="stat-label">إجمالي الباصات</div>
      <div class="stat-change up">عبر جميع المدارس</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#FFF7ED;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="stat-num" id="stat-admins">—</div>
      <div class="stat-label">مديرو المدارس</div>
      <div class="stat-change up">حسابات نشطة</div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">آخر المدارس المضافة</div>
        <div class="card-sub">أحدث 5 مدارس في المنصة</div>
      </div>
      <button class="btn-primary" style="font-size:12px;padding:7px 14px;"
        onclick="showPage('schools',document.querySelector('.nav-item:nth-child(4)'))">عرض الكل</button>
    </div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr>
          <th>المدرسة</th><th>المدينة</th><th>الخطة</th><th>الباصات</th><th>الحالة</th>
        </tr></thead>
        <tbody id="overview-schools-tbody">
          <tr class="skel-row"><td><div class="skel" style="height:16px;width:140px;"></div></td><td><div class="skel" style="height:14px;width:80px;"></div></td><td><div class="skel" style="height:14px;width:60px;"></div></td><td><div class="skel" style="height:14px;width:30px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td></tr>
          <tr class="skel-row"><td><div class="skel" style="height:16px;width:120px;"></div></td><td><div class="skel" style="height:14px;width:70px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td><td><div class="skel" style="height:14px;width:30px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td></tr>
          <tr class="skel-row"><td><div class="skel" style="height:16px;width:160px;"></div></td><td><div class="skel" style="height:14px;width:90px;"></div></td><td><div class="skel" style="height:14px;width:65px;"></div></td><td><div class="skel" style="height:14px;width:30px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ══ SCHOOLS PAGE ══ -->
<div class="page" id="sa-page-schools">

  <div class="filter-bar">
    <button class="filter-btn active" onclick="filterSchools('all',this)">الكل</button>
    <button class="filter-btn" onclick="filterSchools('active',this)">نشطة</button>
    <button class="filter-btn" onclick="filterSchools('inactive',this)">موقوفة</button>
    <button class="filter-btn" onclick="filterSchools('premium',this)">Premium</button>
    <button class="add-btn" onclick="openSchoolModal()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      إضافة مدرسة
    </button>
  </div>

  <!-- Bulk action bar (hidden until rows selected) -->
  <div class="bulk-bar" id="bulk-bar" style="display:none;">
    <span class="bulk-count" id="bulk-count-label">0 مدارس محددة</span>
    <button class="bulk-btn del" onclick="bulkDelete()">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
      حذف المحددة
    </button>
    <button class="bulk-btn" onclick="clearSelection()">إلغاء التحديد</button>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">قائمة المدارس</div>
        <div class="card-sub" id="schools-pager-info">جاري التحميل...</div>
      </div>
      <div style="font-size:22px;font-weight:800;color:var(--pu);" id="schools-total">—</div>
    </div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr>
            <th style="width:36px;"><input type="checkbox" class="cb" id="chk-all" onchange="toggleSelectAll(this.checked)" title="تحديد الكل"/></th>
            <th>المدرسة</th>
            <th>المدينة</th>
            <th>المدير</th>
            <th>الخطة</th>
            <th>الباصات</th>
            <th>تاريخ الإنشاء</th>
            <th>الحالة</th>
            <th>إجراءات</th>
          </tr>
        </thead>
        <tbody id="schools-tbody">
          <tr class="skel-row"><td></td><td><div class="skel" style="height:16px;width:150px;"></div></td><td><div class="skel" style="height:14px;width:80px;"></div></td><td><div class="skel" style="height:14px;width:120px;"></div></td><td><div class="skel" style="height:14px;width:60px;"></div></td><td><div class="skel" style="height:14px;width:30px;"></div></td><td><div class="skel" style="height:14px;width:90px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td><td></td></tr>
          <tr class="skel-row"><td></td><td><div class="skel" style="height:16px;width:130px;"></div></td><td><div class="skel" style="height:14px;width:70px;"></div></td><td><div class="skel" style="height:14px;width:130px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td><td><div class="skel" style="height:14px;width:30px;"></div></td><td><div class="skel" style="height:14px;width:90px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td><td></td></tr>
          <tr class="skel-row"><td></td><td><div class="skel" style="height:16px;width:165px;"></div></td><td><div class="skel" style="height:14px;width:85px;"></div></td><td><div class="skel" style="height:14px;width:115px;"></div></td><td><div class="skel" style="height:14px;width:65px;"></div></td><td><div class="skel" style="height:14px;width:30px;"></div></td><td><div class="skel" style="height:14px;width:90px;"></div></td><td><div class="skel" style="height:14px;width:55px;"></div></td><td></td></tr>
        </tbody>
      </table>
    </div>
    <div class="pager">
      <span class="pager-info" id="schools-pager-text"></span>
      <button class="pager-btn" id="schools-prev" onclick="loadSchools(schoolsPage-1)" disabled>السابق</button>
      <span class="pager-num" id="schools-pager-num"></span>
      <button class="pager-btn" id="schools-next" onclick="loadSchools(schoolsPage+1)" disabled>التالي</button>
    </div>
  </div>
</div>

<!-- ══ ADMINS PAGE ══ -->
<div class="page" id="sa-page-admins">
  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">مديرو المدارس</div>
        <div class="card-sub">قائمة بجميع مديري المدارس المشتركة</div>
      </div>
    </div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr>
          <th>المدرسة</th><th>بريد المدير</th><th>المدينة</th><th>الخطة</th><th>الحالة</th>
        </tr></thead>
        <tbody id="admins-tbody">
          <tr><td colspan="5" style="text-align:center;padding:40px;color:var(--text3);">جاري التحميل...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ PLANS PAGE ══ -->
<div class="page" id="sa-page-plans">
  <div class="stats-grid" style="margin-bottom:0;">
    <div class="stat-card" style="border-top:3px solid #94A3B8;">
      <div class="stat-icon" style="background:#F1F5F9;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>
      </div>
      <div class="stat-num" id="plan-basic-count">—</div>
      <div class="stat-label">خطة أساسية</div>
      <div class="stat-change" style="color:var(--text3);">حتى 5 باصات</div>
    </div>
    <div class="stat-card" style="border-top:3px solid #3B82F6;">
      <div class="stat-icon" style="background:#EFF6FF;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="stat-num" id="plan-standard-count">—</div>
      <div class="stat-label">خطة معيارية</div>
      <div class="stat-change up">حتى 20 باصاً</div>
    </div>
    <div class="stat-card" style="border-top:3px solid #FFD700;">
      <div class="stat-icon" style="background:#FFFDE7;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B8960C" stroke-width="2.5" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="stat-num" id="plan-premium-count">—</div>
      <div class="stat-label">خطة مميزة</div>
      <div class="stat-change up">غير محدود</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#F5F3FF;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      </div>
      <div class="stat-num" id="plan-total-buses">—</div>
      <div class="stat-label">إجمالي الباصات</div>
      <div class="stat-change up">عبر جميع الخطط</div>
    </div>
  </div>

  <div style="margin-top:20px;display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    <div class="card" style="border-top:3px solid #94A3B8;margin-bottom:0;">
      <div class="card-body">
        <div style="font-size:16px;font-weight:800;margin-bottom:4px;">أساسية</div>
        <div style="font-size:13px;color:var(--text2);line-height:1.6;">حتى 5 باصات · تتبع أساسي · تنبيهات SMS · دعم بريد إلكتروني</div>
      </div>
    </div>
    <div class="card" style="border-top:3px solid #3B82F6;margin-bottom:0;">
      <div class="card-body">
        <div style="font-size:16px;font-weight:800;margin-bottom:4px;">معيارية</div>
        <div style="font-size:13px;color:var(--text2);line-height:1.6;">حتى 20 باصاً · تتبع متقدم · إشعارات فورية · تقارير · دعم هاتفي</div>
      </div>
    </div>
    <div class="card" style="border-top:3px solid #FFD700;margin-bottom:0;">
      <div class="card-body">
        <div style="font-size:16px;font-weight:800;margin-bottom:4px;">مميزة ⭐</div>
        <div style="font-size:13px;color:var(--text2);line-height:1.6;">غير محدود · API مفتوح · مدير حساب مخصص · SLA 99.9% · تكامل ERP</div>
      </div>
    </div>
  </div>
</div>

<!-- ══ SETTINGS PAGE ══ -->
<div class="page" id="sa-page-settings">
  <div class="card">
    <div class="card-header"><div class="card-title">إعدادات النظام</div></div>
    <div class="card-body">
      <div style="display:flex;flex-direction:column;gap:12px;">
        <div style="background:var(--bg);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;border-radius:10px;background:#F5F3FF;display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div style="flex:1;"><div style="font-size:13px;font-weight:700;">إصدار النظام</div><div style="font-size:11px;color:var(--text3);">SmartBus Platform v2.0</div></div>
        </div>
        <div style="background:var(--bg);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;border-radius:10px;background:#F0FDF4;display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div style="flex:1;"><div style="font-size:13px;font-weight:700;">حالة الخدمة</div><div style="font-size:11px;color:#15803D;">جميع الأنظمة تعمل بشكل طبيعي ✓</div></div>
        </div>
        <div style="background:var(--bg);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;border-radius:10px;background:#FFFDE7;display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B8960C" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          </div>
          <div style="flex:1;"><div style="font-size:13px;font-weight:700;">بيانات الاعتماد الافتراضية</div><div style="font-size:11px;color:var(--text3);">superadmin@smartbus.com · SuperAdmin@123456</div></div>
        </div>
        <div style="background:var(--bg);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:background .15s;" onclick="openChangePassword()" onmouseenter="this.style.background='var(--pul)'" onmouseleave="this.style.background='var(--bg)'">
          <div style="width:36px;height:36px;border-radius:10px;background:var(--pul);display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div style="flex:1;"><div style="font-size:13px;font-weight:700;">تغيير كلمة المرور</div><div style="font-size:11px;color:var(--text3);">تحديث بيانات الدخول للمشرف العام</div></div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text3)" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </div>
      </div>
    </div>
  </div>
</div>
