@using SmartBus.Application.Common.Models
@using SmartBus.Application.Features.Students.Queries.GetAllStudents
@model PagedResult<StudentDto>

@if (Model is null || !Model.Items.Any())
{
    <tr><td colspan="7" class="u-empty-state">@L["Student_None"]</td></tr>
}
else
{
    foreach (var s in Model.Items)
    {
        var initials = s.FullName.Length >= 2 ? s.FullName[..2] : s.FullName;
        <tr>
            <td>
                <div class="u-flex u-items-center u-gap-10">
                    <div class="table-av">@initials</div>
                    <div><div class="td-name">@s.FullName</div></div>
                </div>
            </td>
            <td>@L["Std_Grade" + s.Grade] @(!string.IsNullOrEmpty(s.Class) ? s.Class : "")</td>
            <td>@(string.IsNullOrEmpty(s.RouteName) ? "—" : Html.Raw($"<span class='badge badge-blue'>{s.RouteName}</span>"))</td>
            <td><div class="td-sub">@s.ParentName</div></td>
            <td><div class="td-sub">@s.ParentPhone</div></td>
            <td><div class="td-sub">@s.CreatedAt.ToString("dd MMM yyyy")</div></td>
            <td>
                <div class="tbl-actions">
                    <button class="tbl-btn tbl-edit" onclick="students.openForm('@s.Id')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
                    </button>
                    <button class="tbl-btn tbl-del"
                            onclick="students.askDelete(this)"
                            data-id="@s.Id" data-name="@s.FullName" data-type="@L["Student_TypeLabel"]">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                </div>
            </td>
        </tr>
    }
}

<tr class="u-hidden">
    <td data-pager-info="@L["Student_PagerInfo", Model?.Items.Count() ?? 0, Model?.TotalCount ?? 0, Model?.PageNumber ?? 1, Model?.TotalPages ?? 1]"
        data-total-pages="@(Model?.TotalPages ?? 1)"
        data-total-count="@(Model?.TotalCount ?? 0)"
        data-page="@(Model?.PageNumber ?? 1)"></td>
</tr>
