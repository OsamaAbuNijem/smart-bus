@model AdminPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

<input type="hidden" id="buses-page" value="1"/>

<div class="filter-bar">
  <button class="filter-btn active">
    الكل (<span id="buses-total">0</span>)
  </button>
  <button class="add-btn" onclick="buses.openForm()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    @L["Bus_AddBtn"]
  </button>
</div>

<div class="card">
  <table class="table">
    <thead>
      <tr><th>@L["Bus_Number"]</th><th>@L["Bus_Capacity"]</th><th>@L["Bus_Status"]</th><th>@L["Bus_Driver"]</th><th>@L["Bus_Assistant"]</th><th>@L["Nav_Students"]</th><th></th></tr>
    </thead>
    <tbody id="buses-tbody">
      <tr><td colspan="7" class="u-loading-state">جاري التحميل...</td></tr>
    </tbody>
  </table>
  <div class="table-pager">
    <span class="table-pager-info" id="buses-pager-info"></span>
    <div class="table-pager-controls">
      <button class="filter-btn" id="buses-prev" onclick="buses.prev()">‹ السابق</button>
      <button class="filter-btn" id="buses-next" onclick="buses.next()">التالي ›</button>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/admin/buses.js" asp-append-version="true"></script>
}
