@using SmartBus.Application.Common.Models
@using SmartBus.Application.Features.Trips.Queries.GetAllTrips
@model PagedResult<TripDto>
@{
    var items = Model?.Items ?? Enumerable.Empty<TripDto>();
    var completed = items.Count(t => t.Status == "Completed");
    var onTime    = items.Count(t => t.Status != "Late");
}

<div class="report-summary-row">
    <div class="report-summary-label">مكتملة</div>
    <div class="report-summary-value success">@completed</div>
</div>
<div class="report-summary-row">
    <div class="report-summary-label">في الموعد</div>
    <div class="report-summary-value info">@onTime</div>
</div>
<div class="report-summary-row">
    <div class="report-summary-label">الإجمالي</div>
    <div class="report-summary-value">@(Model?.TotalCount ?? 0)</div>
</div>
