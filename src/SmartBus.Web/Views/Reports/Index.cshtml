@model DashboardPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

<div class="grid-4">
  <div class="report-stat">
    <div class="report-num blue" id="rpt-students">@Model.TotalStudents</div>
    <div class="report-lbl">إجمالي الطلاب</div>
    <div class="report-sub good">مسجلون في النظام</div>
  </div>
  <div class="report-stat">
    <div class="report-num green" id="rpt-buses">@Model.TotalBuses</div>
    <div class="report-lbl">إجمالي الباصات</div>
    <div class="report-sub good">في الأسطول</div>
  </div>
  <div class="report-stat">
    <div class="report-num yellow" id="rpt-trips">@Model.TotalTrips</div>
    <div class="report-lbl">إجمالي الرحلات</div>
    <div class="report-sub good">مسجلة في النظام</div>
  </div>
  <div class="report-stat">
    <div class="report-num orange" id="rpt-alerts">@Model.PendingAlerts</div>
    <div class="report-lbl">تنبيهات معلقة</div>
    <div class="report-sub bad">تحتاج مراجعة</div>
  </div>
</div>

<div class="grid-2">
  <div class="card">
    <div class="card-header"><div class="card-title">أداء الرحلات</div></div>
    <div class="card-body card-body-flush" id="report-trips-perf">
      <div class="u-loading-state">جاري تحميل التقرير...</div>
    </div>
  </div>
  <div class="card">
    <div class="card-header"><div class="card-title">أداء الباصات</div></div>
    <div class="card-body card-body-flush" id="report-buses-perf">
      <div class="u-loading-state">جاري تحميل التقرير...</div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/admin/reports.js" asp-append-version="true"></script>
}
