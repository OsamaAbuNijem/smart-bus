@using SmartBus.Application.Common.Models
@using SmartBus.Application.Features.Trips.Queries.GetAllTrips
@model PagedResult<TripDto>

@if (Model is null || !Model.Items.Any())
{
    <div class="u-empty-state">@L["Trip_None"]</div>
}
else
{
    foreach (var t in Model.Items)
    {
        var statusKey = $"Trip_Status{t.Status}";
        var (dot, bg, color) = t.Status switch
        {
            "InProgress" => ("#22C55E", "#F0FDF4", "#15803D"),
            "Completed"  => ("#94A3B8", "#F1F5F9", "#475569"),
            "Delayed"    => ("#EF4444", "#FEF2F2", "#B91C1C"),
            "Cancelled"  => ("#EF4444", "#FEF2F2", "#B91C1C"),
            _            => ("#3B82F6", "#EFF6FF", "#1E40AF")
        };
        <div class="trip-row">
            <div class="trip-status-dot" style="background:@dot;"></div>
            <div class="trip-info">
                <div class="trip-name">@t.BusPlateNumber — @(t.RouteName ?? "")</div>
                <div class="trip-meta">@t.ScheduledDeparture.ToString("dd MMM HH:mm")</div>
            </div>
            <div class="trip-badge" style="background:@bg;">
                <span style="color:@color;">@L[statusKey]</span>
            </div>
        </div>
    }
}

<span id="dashboard-trips-count" class="u-hidden">@(Model?.Items.Count() ?? 0)</span>
<span id="dashboard-trips-total" class="u-hidden">@(Model?.TotalCount ?? 0)</span>
