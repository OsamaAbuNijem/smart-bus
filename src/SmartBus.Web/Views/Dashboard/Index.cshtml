@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-primary text-white">
            <div class="card-body d-flex align-items-center p-4">
                <i class="bi bi-bus-front-fill fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalBuses</div>
                    <div class="opacity-75">Total Buses</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-success text-white">
            <div class="card-body d-flex align-items-center p-4">
                <i class="bi bi-map-fill fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalTrips</div>
                    <div class="opacity-75">Total Trips</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-info text-white">
            <div class="card-body d-flex align-items-center p-4">
                <i class="bi bi-activity fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold" id="active-buses">--</div>
                    <div class="opacity-75">Active Now</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-warning text-white">
            <div class="card-body d-flex align-items-center p-4">
                <i class="bi bi-bell-fill fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold" id="notification-count">0</div>
                    <div class="opacity-75">Notifications</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Live Bus Map</h5>
            </div>
            <div class="card-body p-0">
                <div id="map" style="height: 450px; border-radius: 0 0 1rem 1rem;"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-bell text-warning me-2"></i>Live Notifications</h5>
            </div>
            <div class="card-body p-3" id="notification-feed" style="max-height: 420px; overflow-y: auto;">
                <p class="text-muted text-center mt-4">Waiting for real-time updates...</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between">
                <h5 class="fw-bold mb-0"><i class="bi bi-bus-front text-primary me-2"></i>Recent Buses</h5>
                <a asp-controller="Buses" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Plate Number</th>
                                <th>Model</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th>Driver</th>
                                <th class="pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bus in ViewBag.RecentBuses)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">@bus.PlateNumber</td>
                                    <td>@bus.Model</td>
                                    <td>@bus.Capacity</td>
                                    <td>
                                        <span class="badge @(bus.Status == "OnRoute" ? "bg-success" : bus.Status == "Active" ? "bg-primary" : "bg-secondary")">
                                            @bus.Status
                                        </span>
                                    </td>
                                    <td>@(bus.DriverName ?? "Unassigned")</td>
                                    <td class="pe-4">
                                        <a asp-controller="Buses" asp-action="Details" asp-route-id="@bus.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/bus-tracking.js" asp-append-version="true"></script>
}
