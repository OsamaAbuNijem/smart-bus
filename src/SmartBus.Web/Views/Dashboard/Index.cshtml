@model DashboardPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

<div class="stats-grid">
  @await Component.InvokeAsync("StatCard", new {
      color   = "blue",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#3B82F6\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>",
      iconBgClass = "icon-bg-blue", number = Model.TotalStudents, label = "إجمالي الطلاب",
      change  = "مسجلون في النظام", changeDir = "up", numberId = "stat-students"
  })
  @await Component.InvokeAsync("StatCard", new {
      color   = "green",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#22C55E\" stroke-width=\"2\" stroke-linecap=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"2\"/><path d=\"M16 8h4l3 3v5h-7V8z\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg>",
      iconBgClass = "icon-bg-green", number = Model.TotalBuses, label = "إجمالي الباصات",
      change  = $"من أصل {Model.TotalBuses} باص", changeDir = "up", numberId = "stat-buses"
  })
  @await Component.InvokeAsync("StatCard", new {
      color   = "yellow",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#B8960C\" stroke-width=\"2\" stroke-linecap=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"2\"/><path d=\"M16 8h4l3 3v5h-7V8z\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg>",
      iconBgClass = "icon-bg-yellow", number = Model.TotalTrips, label = "الرحلات المسجلة",
      change  = "رحلات في النظام", changeDir = "up", numberId = "stat-trips"
  })
  @await Component.InvokeAsync("StatCard", new {
      color   = "red",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#EF4444\" stroke-width=\"2\" stroke-linecap=\"round\"><polygon points=\"7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"/></svg>",
      iconBgClass = "icon-bg-red", number = Model.PendingAlerts, label = "تنبيهات معلقة",
      change  = "تحتاج مراجعة", changeDir = "down", numberId = "stat-alerts"
  })
</div>

<div class="grid-3">
  <div class="map-card">
    <div class="card-header">
      <div><div class="card-title">خريطة الباصات المباشرة</div><div class="card-sub" id="active-buses-sub">جاري التحميل...</div></div>
      <div class="card-action">عرض موسع ↗</div>
    </div>
    <div class="map-area" id="live-map">
      <div class="map-grid-h r20"></div><div class="map-grid-h r40"></div>
      <div class="map-grid-h r60"></div><div class="map-grid-h r80"></div>
      <div class="map-grid-v c20"></div><div class="map-grid-v c40"></div>
      <div class="map-grid-v c60"></div><div class="map-grid-v c80"></div>
      <div class="map-road-h r19"></div><div class="map-road-h r39"></div><div class="map-road-h r59"></div>
      <div class="map-road-v c19"></div><div class="map-road-v c39"></div><div class="map-road-v c59"></div><div class="map-road-v c79"></div>

      <div class="school-marker">
        <div class="school-marker-box">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <div class="school-marker-label">المدرسة</div>
      </div>

      <div id="dashboard-map"></div>
      <div class="map-controls">
        <div class="mctrl"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
        <div class="mctrl"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
      </div>
    </div>
    <div class="map-legend">
      <div class="legend-item"><div class="legend-dot yellow"></div>الباصات الجارية</div>
      <div class="legend-item"><div class="legend-dot green"></div>وصلت للمدرسة</div>
      <div class="legend-item"><div class="legend-dot blue"></div>رحلة إياب</div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div><div class="card-title">رحلات اليوم</div><div class="card-sub" id="today-trips-sub">جاري التحميل...</div></div>
      <a class="card-action" href="/Trips">عرض الكل</a>
    </div>
    <div class="card-body card-body-flush" id="today-trips-list">
      <div class="u-loading-state">جاري تحميل الرحلات...</div>
    </div>
  </div>
</div>

<div class="grid-2">
  <div class="card">
    <div class="card-header"><div><div class="card-title">الحضور — آخر 7 أيام</div></div></div>
    <div class="card-body">
      <div class="attendance-legend">
        <div class="attendance-legend-item"><div class="attendance-swatch blue"></div>ركبوا</div>
        <div class="attendance-legend-item"><div class="attendance-swatch red-ghost"></div>غائبون</div>
      </div>
      <div class="chart-bars">
        <div class="bar-group"><div class="bar-wrap"><div class="bar blue" style="height:72px;"></div><div class="bar red-ghost" style="height:10px;"></div></div><div class="bar-label">أحد</div></div>
        <div class="bar-group"><div class="bar-wrap"><div class="bar blue" style="height:68px;"></div><div class="bar red-ghost" style="height:14px;"></div></div><div class="bar-label">اثن</div></div>
        <div class="bar-group"><div class="bar-wrap"><div class="bar blue" style="height:75px;"></div><div class="bar red-ghost" style="height:8px;"></div></div><div class="bar-label">ثلا</div></div>
        <div class="bar-group"><div class="bar-wrap"><div class="bar blue" style="height:70px;"></div><div class="bar red-ghost" style="height:12px;"></div></div><div class="bar-label">أرب</div></div>
        <div class="bar-group"><div class="bar-wrap"><div class="bar blue" style="height:65px;"></div><div class="bar red-ghost" style="height:18px;"></div></div><div class="bar-label">خمس</div></div>
        <div class="bar-group"><div class="bar-wrap"><div class="bar blue faded" style="height:78px;"></div><div class="bar red-ghost faded" style="height:5px;"></div></div><div class="bar-label">جمع</div></div>
        <div class="bar-group"><div class="bar-wrap"><div class="bar yellow" style="height:74px;"></div><div class="bar red-ghost" style="height:9px;"></div></div><div class="bar-label">سبت</div></div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <div><div class="card-title">التنبيهات الأخيرة</div></div>
      <a class="card-action" href="/Alerts">عرض الكل</a>
    </div>
    <div class="card-body card-body-flush" id="dashboard-alerts">
      <div class="u-loading-state">جاري تحميل التنبيهات...</div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/admin/dashboard.js" asp-append-version="true"></script>
}
