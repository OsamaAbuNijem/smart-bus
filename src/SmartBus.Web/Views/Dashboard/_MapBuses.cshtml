@using SmartBus.Application.Common.Models
@using SmartBus.Application.Features.Buses.Queries.GetAllBuses
@model PagedResult<BusDto>
@{
    var colors    = new[] { "#FFD700","#22C55E","#3B82F6","#F97316","#8B5CF6","#EF4444" };
    var positions = new[]
    {
        ("45%","38%"), ("65%","22%"), ("28%","60%"),
        ("72%","60%"), ("50%","75%"), ("35%","45%")
    };
    var items = (Model?.Items ?? Enumerable.Empty<BusDto>()).Take(6).ToList();
}

@for (var i = 0; i < items.Count; i++)
{
    var b     = items[i];
    var pos   = positions[i];
    var color = colors[i % colors.Length];
    <div class="map-bus" style="top:@pos.Item1;left:@pos.Item2;">
        <div class="mbus-pulse" style="background:@(color)30;"></div>
        <div class="mbus-pin" style="background:@color;">
            <svg width="18" height="12" viewBox="0 0 24 16" fill="none">
              <rect x="1" y="1" width="22" height="12" rx="3" fill="white"/>
              <circle cx="6" cy="14" r="2" fill="white"/><circle cx="18" cy="14" r="2" fill="white"/>
            </svg>
        </div>
        <div class="mbus-label">@b.PlateNumber</div>
    </div>
}

<span id="dashboard-map-count" class="u-hidden">@(Model?.Items.Count() ?? 0)</span>
