@model AdminPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

<div class="settings-grid">
  <div>
    <div class="settings-section">
      <div class="settings-section-title">الإشعارات</div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-yellow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B8960C" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">تنبيهات SOS</div><div class="setting-sub">إشعار فوري عند أي طارئ</div></div>
        <div class="toggle on" data-action="toggle-switch"><div class="toggle-knob"></div></div>
      </div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-orange"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">تنبيهات التأخير</div><div class="setting-sub">عند تأخر الباص أكثر من 5 دقائق</div></div>
        <div class="toggle on" data-action="toggle-switch"><div class="toggle-knob"></div></div>
      </div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-blue"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">تقرير يومي</div><div class="setting-sub">إرسال تقرير يومي بالبريد</div></div>
        <div class="toggle off" data-action="toggle-switch"><div class="toggle-knob"></div></div>
      </div>
    </div>
    <div class="settings-section">
      <div class="settings-section-title">المدرسة</div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-green"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">معلومات المدرسة</div><div class="setting-sub">@(string.IsNullOrEmpty(Model.SchoolName) ? "—" : Model.SchoolName)</div></div>
        <div class="setting-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
      </div>
      <div class="setting-row u-cursor-pointer" data-action="open-change-password">
        <div class="setting-icon icon-bg-purple"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">تغيير كلمة المرور</div><div class="setting-sub">تحديث بيانات الدخول</div></div>
        <div class="setting-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
      </div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-blue"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">إدارة المستخدمين</div><div class="setting-sub">حسابات النظام</div></div>
        <div class="setting-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
      </div>
    </div>
  </div>
  <div>
    <div class="settings-section">
      <div class="settings-section-title">النظام</div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-blue"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">اللغة</div></div>
        <div class="setting-value">العربية</div>
        <div class="setting-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
      </div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-gray"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">الوضع الليلي</div></div>
        <div class="toggle off" data-action="toggle-switch"><div class="toggle-knob"></div></div>
      </div>
      <div class="setting-row">
        <div class="setting-icon icon-bg-green"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <div class="u-flex-1"><div class="setting-title">النسخ الاحتياطي</div><div class="setting-sub">آخر نسخة: اليوم 6:00 ص</div></div>
        <div class="setting-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
      </div>
    </div>
    <div class="settings-section">
      <div class="settings-section-title">الباقة</div>
      <div class="plan-card">
        <div class="plan-card-label">الباقة الحالية</div>
        <div class="plan-card-name">Premium Plan</div>
        <div class="plan-card-expiry">تنتهي 30 يونيو 2026</div>
        <div class="plan-card-features">
          <div class="plan-card-feature">✓ طلاب غير محدود</div>
          <div class="plan-card-feature">✓ تتبع GPS</div>
          <div class="plan-card-feature">✓ تقارير متقدمة</div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/admin/settings.js" asp-append-version="true"></script>
}
