@model DashboardPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
    var culture  = System.Globalization.CultureInfo.CurrentUICulture;
    var today    = DateTime.Now;
    var hour     = today.Hour;
    var greeting = L[hour < 12 ? "Dash_GreetMorning" : (hour < 18 ? "Dash_GreetAfternoon" : "Dash_GreetEvening")].Value;
    var dateFmt  = culture.TextInfo.IsRightToLeft ? "dddd، dd MMMM yyyy" : "dddd, dd MMMM yyyy";
}

<div class="dash-fade">

<div class="dash-hero">
  <div class="dash-hero-inner">
    <div class="dash-hero-left">
      <div class="dash-hero-greet">@greeting، @L["Dash_AdminUser"]</div>
      <div class="dash-hero-title">@(string.IsNullOrWhiteSpace(Model.SchoolName) ? L["Dash_FallbackTitle"].Value : Model.SchoolName)</div>
      <div class="dash-hero-sub">
        @if (!string.IsNullOrWhiteSpace(Model.SchoolCity))
        {
          <span>@Model.SchoolCity</span>
          <span class="dash-hero-dot">•</span>
        }
        <span>@today.ToString(dateFmt, culture)</span>
      </div>
    </div>
    <div class="dash-hero-right">
      <div class="dash-hero-chip">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span>@today.ToString("dd/MM/yyyy")</span>
      </div>
      <button class="dash-hero-refresh" id="dash-refresh" aria-label="@L["Dash_Refresh"]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        <span>@L["Dash_Refresh"]</span>
      </button>
    </div>
  </div>
</div>

<div class="section-head"><span>@L["Dash_SectionKPI"]</span></div>

<div class="stats-grid">
  @await Component.InvokeAsync("StatCard", new {
      color   = "blue",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#3B82F6\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>",
      iconBgClass = "icon-bg-blue", number = Model.TotalStudents, label = L["Dash_Stat_Students"].Value,
      change  = L["Dash_Stat_StudentsSub"].Value, changeDir = "up", numberId = "stat-students"
  })
  @await Component.InvokeAsync("StatCard", new {
      color   = "green",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#22C55E\" stroke-width=\"2\" stroke-linecap=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"2\"/><path d=\"M16 8h4l3 3v5h-7V8z\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg>",
      iconBgClass = "icon-bg-green", number = Model.TotalBuses, label = L["Dash_Stat_Buses"].Value,
      change  = L["Dash_Stat_BusesSub"].Value, changeDir = "up", numberId = "stat-buses"
  })
  @await Component.InvokeAsync("StatCard", new {
      color   = "yellow",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#B8960C\" stroke-width=\"2\" stroke-linecap=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"2\"/><path d=\"M16 8h4l3 3v5h-7V8z\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg>",
      iconBgClass = "icon-bg-yellow", number = Model.TotalTrips, label = L["Dash_Stat_Trips"].Value,
      change  = L["Dash_Stat_TripsSub"].Value, changeDir = "up", numberId = "stat-trips"
  })
  @await Component.InvokeAsync("StatCard", new {
      color   = "red",
      iconSvg = "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#EF4444\" stroke-width=\"2\" stroke-linecap=\"round\"><polygon points=\"7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"/></svg>",
      iconBgClass = "icon-bg-red", number = Model.PendingAlerts, label = L["Dash_Stat_Alerts"].Value,
      change  = L["Dash_Stat_AlertsSub"].Value, changeDir = "down", numberId = "stat-alerts"
  })
</div>

<div class="section-head"><span>@L["Dash_SectionPerf"]</span></div>

<div class="grid-3">
  <div class="card card-hover">
    <div class="card-header">
      <div>
        <div class="card-title">@L["Dash_Card_Weekly"]</div>
        <div class="card-sub" id="weekly-chart-sub">@L["Dash_Loading"]</div>
      </div>
    </div>
    <div class="card-body">
      <div class="chart-wrap chart-wrap-bar"><canvas id="chart-weekly"></canvas></div>
    </div>
  </div>

  <div class="card card-hover">
    <div class="card-header">
      <div>
        <div class="card-title">@L["Dash_Card_TodayStatus"]</div>
        <div class="card-sub" id="status-chart-sub">@L["Dash_Loading"]</div>
      </div>
    </div>
    <div class="card-body">
      <div class="chart-wrap"><canvas id="chart-trip-status"></canvas></div>
      <div class="legend-strip" id="legend-status"></div>
    </div>
  </div>
</div>

<div class="grid-3">
  <div class="card card-hover">
    <div class="card-header">
      <div>
        <div class="card-title">@L["Dash_Card_TodayTrips"]</div>
        <div class="card-sub" id="today-trips-sub">@L["Dash_Loading"]</div>
      </div>
      <a class="card-action" href="/Trips">@L["Dash_ViewAll"]</a>
    </div>
    <div class="card-body card-body-flush" id="today-trips-list">
      <div class="u-loading-state">@L["Dash_LoadingTrips"]</div>
    </div>
  </div>

  <div class="card card-hover">
    <div class="card-header">
      <div>
        <div class="card-title">@L["Dash_Card_TypeDonut"]</div>
        <div class="card-sub" id="type-chart-sub">@L["Dash_Loading"]</div>
      </div>
    </div>
    <div class="card-body">
      <div class="chart-wrap"><canvas id="chart-trip-type"></canvas></div>
      <div class="legend-strip" id="legend-type"></div>
    </div>
  </div>
</div>

<div class="section-head"><span>@L["Dash_SectionAlerts"]</span></div>

<div class="card card-hover">
  <div class="card-header">
    <div>
      <div class="card-title">@L["Dash_Card_RecentAlerts"]</div>
      <div class="card-sub">@string.Format(L["Dash_Card_RecentAlertsSub"].Value, 5)</div>
    </div>
    <a class="card-action" href="/Alerts">@L["Dash_ViewAll"]</a>
  </div>
  <div class="card-body card-body-flush" id="dashboard-alerts">
    <div class="u-loading-state">@L["Dash_LoadingAlerts"]</div>
  </div>
</div>

</div>

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="~/js/admin/dashboard.js" asp-append-version="true"></script>
}
