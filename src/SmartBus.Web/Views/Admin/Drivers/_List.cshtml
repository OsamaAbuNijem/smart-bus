@using SmartBus.Application.Common.Models
@using SmartBus.Application.Features.Drivers.Queries.GetAllDrivers
@model PagedResult<DriverDto>
@functions {
    /// <summary>Display the local 9-digit form for inline editing; we re-add the leading "0" on submit.</summary>
    string LocalPhone(string s) => string.IsNullOrEmpty(s) ? string.Empty : (s.StartsWith("0") ? s[1..] : s);
}

@if (Model is null || !Model.Items.Any())
{
    <tr><td colspan="5" class="u-empty-state">@L["Driver_None"]</td></tr>
}
else
{
    foreach (var d in Model.Items)
    {
        var isAssist    = d.DriverType == SmartBus.Domain.Enums.DriverType.Assistant;
        var typeLabel   = isAssist ? L["Driver_TypeAssist"] : L["Driver_TypeDriver"];
        var typeCls     = isAssist ? "badge-purple" : "badge-blue";
        var activeLabel = d.IsActive ? L["Driver_Active"] : L["Driver_Inactive"];
        var activeCls   = d.IsActive ? "badge-green" : "badge-gray";

        <tr>
            <td>
                <input type="text"
                       class="driver-inline-edit"
                       value="@d.FullName"
                       data-id="@d.Id"
                       data-field="fullName"
                       data-original="@d.FullName"
                       onblur="drivers.commit(this)"
                       onkeydown="drivers.onKey(event)"
                       maxlength="100"
                       autocomplete="off"/>
            </td>
            <td>
                <div class="driver-phone-edit" dir="ltr">
                    <span class="prefix-static">+962</span>
                    <input type="tel"
                           class="driver-inline-edit driver-phone-input"
                           value="@LocalPhone(d.PhoneNumber)"
                           data-id="@d.Id"
                           data-field="phoneNumber"
                           data-original="@LocalPhone(d.PhoneNumber)"
                           onblur="drivers.commit(this)"
                           onkeydown="drivers.onKey(event)"
                           pattern="^7[789]\d{7}$"
                           inputmode="numeric"
                           maxlength="9"
                           autocomplete="off"/>
                </div>
            </td>
            <td>
                <button type="button"
                        class="badge @typeCls driver-pill"
                        data-id="@d.Id" data-current="@d.DriverType"
                        title="@L["Driver_ToggleType"]"
                        onclick="drivers.toggleType(this)">
                    @typeLabel
                </button>
            </td>
            <td>
                <button type="button"
                        class="badge @activeCls driver-pill"
                        data-id="@d.Id" data-current="@(d.IsActive ? "true" : "false")"
                        title="@L["Driver_ToggleStatus"]"
                        onclick="drivers.toggleStatus(this)">
                    @activeLabel
                </button>
            </td>
            <td>
                <div class="tbl-actions">
                    <button class="tbl-btn tbl-del"
                            onclick="drivers.askDelete(this)"
                            data-id="@d.Id"
                            data-name="@d.FullName"
                            data-type="@L["Driver_TypeLabel"]">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                </div>
            </td>
        </tr>
    }
}

<tr class="u-hidden">
    <td data-pager-info="@L["Driver_PagerInfo", Model?.Items.Count() ?? 0, Model?.TotalCount ?? 0, Model?.PageNumber ?? 1, Model?.TotalPages ?? 1]"
        data-total-pages="@(Model?.TotalPages ?? 1)"
        data-total-count="@(Model?.TotalCount ?? 0)"
        data-page="@(Model?.PageNumber ?? 1)"></td>
</tr>
