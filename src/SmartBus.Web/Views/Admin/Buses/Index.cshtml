@model AdminPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

<input type="hidden" id="buses-page"        value="1"/>
<input type="hidden" id="buses-plate"       value=""/>

<div class="filter-bar panel">
  <div class="filter-group">
    @* Honeypot decoys — Chrome re-runs autofill after every DOM change (modal open,
       partial swap, etc.). These absorb the autofill instead of the real inputs. *@
    <input type="text"     class="u-honeypot" tabindex="-1" aria-hidden="true"
           autocomplete="username"          name="fake-user"/>
    <input type="password" class="u-honeypot" tabindex="-1" aria-hidden="true"
           autocomplete="current-password"  name="fake-pass"/>

    <input type="search"
           id="buses-plate-input"
           name="search-plate"
           class="form-input"
           placeholder="@L["Bus_SearchNumber"]"
           value=""
           readonly
           onfocus="this.removeAttribute('readonly')"
           onblur="this.setAttribute('readonly','')"
           autocomplete="off"
           autocorrect="off"
           autocapitalize="none"
           spellcheck="false"
           data-lpignore="true"
           data-form-type="other"
           oninput="buses.onPlateSearch(this.value)"/>
  </div>

  <div class="action-group">
    <button class="add-btn" onclick="buses.openBatchForm()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      @L["Bus_AddBtn"]
    </button>
  </div>
</div>

<div class="card">
  <table class="table">
    <thead>
      <tr>
        <th scope="col">@L["Bus_Number"]</th>
        <th scope="col">@L["Bus_Status"]</th>
        <th scope="col">@L["Bus_QRTitle"]</th>
        <th scope="col"></th>
      </tr>
    </thead>
    <tbody id="buses-tbody">
      <tr><td colspan="4" class="u-loading-state">@L["Bus_Loading"]</td></tr>
    </tbody>
  </table>
  <div class="table-pager">
    <div class="u-flex u-items-center u-gap-12">
      <span class="count-pill accent" aria-live="polite">
        <span>@L["Bus_TotalLabel"]</span>
        <span class="count" id="buses-total">0</span>
      </span>
      <span class="table-pager-info" id="buses-pager-info" aria-live="polite"></span>
    </div>
    <div class="table-pager-controls">
      <button class="filter-btn" id="buses-prev" onclick="buses.prev()">@L["Pager_Prev"]</button>
      <button class="filter-btn" id="buses-next" onclick="buses.next()">@L["Pager_Next"]</button>
    </div>
  </div>
</div>

<!-- Bulk-add modal — "Add N buses" -->
<div class="modal-overlay" id="modal-bus-batch">
  <div class="modal-box sm">
    <div class="modal-header">
      <div>
        <div class="modal-header-title">@L["Bus_Batch_Title"]</div>
        <div class="modal-header-sub">@L["Bus_Batch_Hint"]</div>
      </div>
      <button class="modal-close-btn" data-action="modal-close" data-target="modal-bus-batch">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <label class="form-label" for="bus-batch-count">@L["Bus_Batch_Count"]</label>
      <input id="bus-batch-count" type="number" min="1" max="200" value="1" class="form-input"/>
    </div>
    <div class="modal-footer">
      <button id="bus-batch-save" class="btn-primary" onclick="buses.submitBatch()">@L["Bus_Batch_Create"]</button>
      <button class="btn-secondary" data-action="modal-close" data-target="modal-bus-batch">@L["Del_Cancel"]</button>
    </div>
  </div>
</div>

<!-- Bus QR modal — shows the QR poster the driver/assistant scans to start a trip -->
<div class="modal-overlay" id="modal-bus-qr">
  <div class="modal-box sm">
    <div class="modal-header">
      <div>
        <div class="modal-header-title">@L["Bus_QRTitle"]</div>
        <div class="modal-header-sub" id="bus-qr-plate"></div>
      </div>
      <button class="modal-close-btn" data-action="modal-close" data-target="modal-bus-qr">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body center">
      <div id="bus-qr-canvas" class="bus-qr-canvas"></div>
      <div class="bus-qr-token" id="bus-qr-token"></div>
      <div class="modal-body-line">@L["Bus_QRHint"]</div>
    </div>
    <div class="modal-footer center">
      <button class="btn-primary" id="bus-qr-print">@L["Bus_QRPrint"]</button>
      <button class="btn-secondary" data-action="modal-close" data-target="modal-bus-qr">@L["Del_Cancel"]</button>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/admin/buses.js" asp-append-version="true"></script>
}
