@using SmartBus.Application.Common.Models
@using SmartBus.Application.Features.Buses.Queries.GetAllBuses
@model PagedResult<BusDto>

@if (Model is null || !Model.Items.Any())
{
    <tr><td colspan="8" class="u-empty-state">@L["Bus_None"]</td></tr>
}
else
{
    var rowIndex = ((Model.PageNumber - 1) * Model.PageSize);
    foreach (var b in Model.Items)
    {
        rowIndex++;
        var (statusCls, statusLabel) = b.Status == "Active"
            ? ("badge-green", L["Bus_StatusActive"].Value + " 🟢")
            : ("badge-gray",  L["Bus_StatusInactive"].Value);
        var rowCls     = b.IsScheduleComplete ? "" : "row-incomplete";
        var schedCls   = b.IsScheduleComplete ? "tbl-sched" : "tbl-sched tbl-sched-warn";
        var schedStroke = b.IsScheduleComplete ? "#0EA5E9" : "#B45309";
        var schedTitle = b.IsScheduleComplete
            ? L["BusSchedule_Title"].Value
            : L["BusSchedule_Title"].Value + " — " + L["BusSchedule_Incomplete"].Value;
        <tr class="@rowCls">
            <td class="td-rownum">@rowIndex</td>
            <td><div class="td-name">@b.PlateNumber</div></td>
            <td>@b.Capacity</td>
            <td><span class="badge @statusCls">@statusLabel</span></td>
            <td><div class="td-sub">@(string.IsNullOrEmpty(b.DriverName) ? "—" : b.DriverName)</div></td>
            <td><div class="td-sub">@(string.IsNullOrEmpty(b.AssistantDriverName) ? "—" : b.AssistantDriverName)</div></td>
            <td><span class="badge badge-blue">@b.StudentCount</span></td>
            <td>
                <div class="tbl-actions">
                    <button class="tbl-btn @schedCls tbl-btn-wrap" title="@schedTitle" onclick="buses.openSchedule('@b.Id')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="@schedStroke" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        @if (!b.IsScheduleComplete)
                        {
                            <span class="badge-incomplete" aria-label="@L["BusSchedule_Incomplete"]">⚠</span>
                        }
                    </button>
                    <button class="tbl-btn tbl-qr" title="@L["Bus_QRTitle"]"
                            data-qr="@b.QrToken" data-plate="@b.PlateNumber"
                            onclick="buses.openQr(this)">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><line x1="14" y1="14" x2="14" y2="17"/><line x1="17" y1="14" x2="21" y2="14"/><line x1="14" y1="20" x2="17" y2="20"/><line x1="20" y1="17" x2="20" y2="21"/></svg>
                    </button>
                    <button class="tbl-btn tbl-edit" onclick="buses.openForm('@b.Id')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
                    </button>
                    <button class="tbl-btn tbl-del"
                            onclick="buses.askDelete(this)"
                            data-id="@b.Id" data-name="@b.PlateNumber" data-type="@L["Bus_TypeLabel"]">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                </div>
            </td>
        </tr>
    }
}

<tr class="u-hidden">
    <td data-pager-info="@L["Bus_PagerInfo", Model?.Items.Count() ?? 0, Model?.TotalCount ?? 0, Model?.PageNumber ?? 1, Model?.TotalPages ?? 1]"
        data-total-pages="@(Model?.TotalPages ?? 1)"
        data-total-count="@(Model?.TotalCount ?? 0)"
        data-page="@(Model?.PageNumber ?? 1)"></td>
</tr>
