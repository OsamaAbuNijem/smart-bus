@model SmartBus.Web.Models.StudentInput?
@{
    var isEdit    = ViewBag.StudentId is not null;
    var studentId = ViewBag.StudentId as Guid?;
    var errors    = ViewData.ModelState;
    string? ErrFor(string key) => errors[key]?.Errors.FirstOrDefault()?.ErrorMessage;

    // The phone is stored canonical "+9627XXXXXXXX"; strip the country dial
    // so the input shows the 9-digit local part next to the "+962" chip.
    string LocalPhone(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        var s = raw.Trim();
        if (s.StartsWith("+962")) s = s[4..];
        else if (s.StartsWith("962")) s = s[3..];
        else if (s.StartsWith("0")) s = s[1..];
        return s;
    }
}

<form id="student-form"
      data-id="@studentId"
      onsubmit="event.preventDefault(); students.submit(this);">

  <div class="modal-header">
    <div class="modal-header-title">@(isEdit ? L["Std_EditTitle"] : L["Std_AddTitle"])</div>
    <button type="button" class="modal-close-btn" onclick="SB.closeModal('modal-student')">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="modal-body">
    @if (errors.ErrorCount > 0)
    {
        <div class="form-server-err" style="display:block; margin-bottom:14px;">
            @foreach (var state in errors)
            {
                foreach (var err in state.Value.Errors)
                {
                    <div>@(string.IsNullOrEmpty(state.Key) ? "" : state.Key + ": ")@err.ErrorMessage</div>
                }
            }
        </div>
    }

    @* ── Section: Student Info ────────────────────────────────────── *@
    <section class="form-section">
      <header class="form-section-head">
        <span class="form-section-ico sb-student">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
        </span>
        <div>
          <div class="form-section-title">@L["Std_SectionStudent"]</div>
          <div class="form-section-sub">@L["Std_SectionStudent_Sub"]</div>
        </div>
      </header>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["Std_Name"]</label>
          <input type="text" name="FullName" class="form-input" dir="rtl" value="@Model?.FullName"/>
          @if (ErrFor(nameof(StudentInput.FullName)) is { } e1) { <span class="form-err" style="display:block;">@e1</span> }
        </div>
        <div class="form-group">
          <label class="form-label">@L["Std_NameEn"]</label>
          <input type="text" name="FullNameEn" class="form-input" dir="ltr" value="@Model?.FullNameEn"/>
        </div>
      </div>

      <div class="form-row full">
        <div class="form-group">
          <label class="form-label">@L["Std_NationalNumber"]</label>
          <input type="text" name="NationalNumber" class="form-input" dir="ltr"
                 pattern="^\d{10}$"
                 inputmode="numeric"
                 maxlength="10"
                 placeholder="1234567890"
                 value="@Model?.NationalNumber"/>
          @if (ErrFor(nameof(StudentInput.NationalNumber)) is { } eNat) { <span class="form-err" style="display:block;">@eNat</span> }
        </div>
      </div>
      @* Grade removed from the UI — value round-trips so existing rows keep their grade. *@
      <input type="hidden" name="Grade" value="@(string.IsNullOrEmpty(Model?.Grade) ? "1" : Model.Grade)"/>
    </section>

    @* ── Section: Parent Info ─────────────────────────────────────── *@
    <section class="form-section">
      <header class="form-section-head">
        <span class="form-section-ico sb-parent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </span>
        <div>
          <div class="form-section-title">@L["Std_SectionParent"]</div>
          <div class="form-section-sub">@L["Std_SectionParent_Sub"]</div>
        </div>
      </header>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["Std_Parent"]</label>
          <input type="text" name="ParentName" class="form-input" dir="rtl" value="@Model?.ParentName"/>
          @if (ErrFor(nameof(StudentInput.ParentName)) is { } e2) { <span class="form-err" style="display:block;">@e2</span> }
        </div>
        <div class="form-group">
          <label class="form-label">@L["Std_Phone"]</label>
          <div class="form-input-group" dir="ltr">
            <span class="prefix">+962</span>
            <input type="tel" name="ParentPhone"
                   pattern="^7[789]\d{7}$"
                   placeholder="79XXXXXXX"
                   inputmode="numeric"
                   maxlength="9"
                   value="@LocalPhone(Model?.ParentPhone)"/>
          </div>
          @if (ErrFor(nameof(StudentInput.ParentPhone)) is { } e3) { <span class="form-err" style="display:block;">@e3</span> }
        </div>
      </div>
    </section>

    @* Home Address removed from the UI — values round-trip so existing data isn't lost on edit. *@
    <input type="hidden" name="Latitude"           id="sf-lat"    value="@(Model?.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))"/>
    <input type="hidden" name="Longitude"          id="sf-lng"    value="@(Model?.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))"/>
    <input type="hidden" name="HomeArea"           id="sf-area"   value="@Model?.HomeArea"/>
    <input type="hidden" name="HomeStreet"         id="sf-street" value="@Model?.HomeStreet"/>
    <input type="hidden" name="HomeBuildingNumber"                value="@Model?.HomeBuildingNumber"/>
  </div>

  <div class="modal-footer">
    <button type="submit" class="btn-primary">@L["Std_SaveBtn"]</button>
    <button type="button" class="btn-secondary" onclick="SB.closeModal('modal-student')">@L["Std_Cancel"]</button>
  </div>
</form>
