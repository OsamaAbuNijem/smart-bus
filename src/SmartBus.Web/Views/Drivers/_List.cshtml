@using SmartBus.Application.Common.Models
@using SmartBus.Application.Features.Drivers.Queries.GetAllDrivers
@model PagedResult<DriverDto>
@{
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
}

@if (Model is null || !Model.Items.Any())
{
    <tr><td colspan="6" class="u-empty-state">@L["Driver_None"]</td></tr>
}
else
{
    foreach (var d in Model.Items)
    {
        var displayName = !isRtl && !string.IsNullOrEmpty(d.FullNameEn) ? d.FullNameEn : d.FullName;
        var isAssist    = d.DriverType == SmartBus.Domain.Enums.DriverType.Assistant;
        var typeLabel   = isAssist ? L["Driver_TypeAssist"] : L["Driver_TypeDriver"];
        var typeCls     = isAssist ? "badge-purple" : "badge-blue";
        var activeLabel = d.IsActive ? L["Driver_Active"] : L["Driver_Inactive"];
        var activeCls   = d.IsActive ? "badge-green" : "badge-gray";
        var initials    = displayName.Length >= 2 ? displayName[..2] : displayName;

        <tr>
            <td>
                <div class="u-flex u-items-center u-gap-10">
                    <div class="table-av">@initials</div>
                    <div><div class="td-name">@displayName</div></div>
                </div>
            </td>
            <td><span class="badge @typeCls">@typeLabel</span></td>
            <td>@(string.IsNullOrEmpty(d.LicenseNumber) ? "—" : d.LicenseNumber)</td>
            <td>@d.PhoneNumber</td>
            <td><span class="badge @activeCls">@activeLabel@(d.IsActive ? " 🟢" : "")</span></td>
            <td>
                <div class="tbl-actions">
                    <button class="tbl-btn tbl-edit" onclick="drivers.openForm('@d.Id')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
                    </button>
                    <button class="tbl-btn tbl-del"
                            onclick="drivers.askDelete(this)"
                            data-id="@d.Id"
                            data-name="@d.FullName"
                            data-type="@L["Driver_TypeDriver"]">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                </div>
            </td>
        </tr>
    }
}

<tr class="u-hidden">
    <td data-pager-info="@L["Driver_PagerInfo", Model?.Items.Count() ?? 0, Model?.TotalCount ?? 0, Model?.PageNumber ?? 1, Model?.TotalPages ?? 1]"
        data-total-pages="@(Model?.TotalPages ?? 1)"
        data-total-count="@(Model?.TotalCount ?? 0)"
        data-page="@(Model?.PageNumber ?? 1)"></td>
</tr>
