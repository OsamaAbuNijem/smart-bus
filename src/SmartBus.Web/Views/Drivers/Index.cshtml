@model AdminPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

@* All page state lives in hidden inputs — no JS-side state. *@
<input type="hidden" id="drivers-page"   value="1"/>
<input type="hidden" id="drivers-filter" value=""/>

<div class="filter-bar">
  <button class="filter-btn active" onclick="drivers.filter('', this)">
    الكل (<span id="drivers-total">0</span>)
  </button>
  <button class="filter-btn"        onclick="drivers.filter('Driver', this)">@L["Driver_TypeDriver"]</button>
  <button class="filter-btn"        onclick="drivers.filter('Assistant', this)">@L["Driver_TypeAssist"]</button>
  <button class="add-btn" onclick="drivers.openForm()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    @L["Driver_AddTitle"]
  </button>
</div>

<div class="card">
  <table class="table">
    <thead>
      <tr><th>الموظف</th><th>الدور</th><th>رقم الرخصة</th><th>رقم التواصل</th><th>الحالة</th><th></th></tr>
    </thead>
    <tbody id="drivers-tbody">
      <tr><td colspan="6" class="u-loading-state">جاري التحميل...</td></tr>
    </tbody>
  </table>
  <div class="table-pager">
    <span class="table-pager-info" id="drivers-pager-info"></span>
    <div class="table-pager-controls">
      <button class="filter-btn" id="drivers-prev" onclick="drivers.prev()">‹ السابق</button>
      <button class="filter-btn" id="drivers-next" onclick="drivers.next()">التالي ›</button>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/admin/drivers.js" asp-append-version="true"></script>
}
