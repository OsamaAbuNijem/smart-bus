    schoolDeleted      = L["JS_SchoolDeleted"].Value,
    schoolDeleteFailed = L["JS_SchoolDeleteFailed"].Value,
    statusActivated    = L["JS_StatusActivated"].Value,
    statusDeactivated  = L["JS_StatusDeactivated"].Value,
    statusFailed       = L["JS_StatusFailed"].Value,
    planChanged        = L["JS_PlanChanged"].Value,
    planFailed         = L["JS_PlanFailed"].Value,
    exportNoData       = L["JS_ExportNoData"].Value,
    exportDone         = L["JS_ExportDone"].Value,
    exportCSV          = L["JS_ExportCSV"].Value,
    passwordChanged    = L["JS_PasswordChanged"].Value,
    deletedSuccess     = L["JS_DeletedSuccess"].Value,
    saveFailed         = L["JS_SaveFailed"].Value,
    saving             = L["JS_Saving"].Value,
    saveSchoolBtn      = L["JS_SaveSchoolBtn"].Value,
    pageOverview       = L["JS_PageOverview"].Value,
    pageSchools        = L["JS_PageSchools"].Value,
    pageAdmins         = L["JS_PageAdmins"].Value,
    pagePlans          = L["JS_PagePlans"].Value,
    pageSettings       = L["JS_PageSettings"].Value,
    isRtl = _isRtl,
    dir   = _dir,
}));
</script>
