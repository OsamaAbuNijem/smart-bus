        "<span id="del-school-name" style="color:#DC2626;font-weight:700;"></span>"<br/>
        <span style="color:#EF4444;font-size:12px;">هذا الإجراء لا يمكن التراجع عنه.</span>
      </div>
    </div>
    <div class="modal-footer" style="justify-content:center;gap:12px;">
