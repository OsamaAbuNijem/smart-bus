      <button class="btn-secondary" onclick="closeModal('modal-delete')">إلغاء</button>
    </div>
  </div>
</div>

<!-- MODAL: CHANGE PASSWORD -->
<div class="modal-overlay" id="modal-change-password">
  <div class="modal-box" style="max-width:420px;">
    <div class="modal-header">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:32px;height:32px;border-radius:9px;background:var(--pul);display:flex;align-items:center;justify-content:center;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="modal-header-title">تغيير كلمة المرور</div>
      </div>
      <button class="modal-close-btn" onclick="closeModal('modal-change-password')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
      <div class="form-group">
        <label class="form-label">كلمة المرور الحالية</label>
        <input type="password" id="cp-current" class="form-input" placeholder="••••••••" autocomplete="current-password"/>
        <span class="form-err" id="err-cp-current">هذا الحقل مطلوب</span>
      </div>
      <div class="form-group">
        <label class="form-label">كلمة المرور الجديدة</label>
        <input type="password" id="cp-new" class="fform-input" placeholder="8 أحرف على الأقل" autocomplete="new-password"/>
        <span class="form-err" id="err-cp-new">8 أحرف على الأقل</span>
      </div>
      <div class="form-group">
        <label class="form-label">تأكيد كلمة المرور</label>
        <input type="password" id="cp-confirm" class="form-input" placeholder="••••••••" autocomplete="new-password"/>
        <span class="form-err" id="err-cp-confirm">كلمتا المرور غير متطابقتين</span>
      </div>
      <div id="cp-server-err" style="display:none;background:#FEF2F2;border:1px solid #FECACA;border-radius:8px;padding:10px 12px;font-size:12px;color:#DC2626;"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" id="btn-save-password" onclick="changePassword()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        حفظ كلمة المرور
      </button>
      <button class="btn-secondary" onclick="closeModal('modal-change-password')">إلغاء</button>
    </div>
  </div>
</div>

<script>
window.T = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
