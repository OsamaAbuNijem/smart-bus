<div class="modal-overlay" id="modal-delete">
  <div class="modal-box xs">
    <div class="modal-header">
      <div class="modal-header-title danger">@L["Del_Title"]</div>
      <button class="modal-close-btn" data-action="modal-close" data-target="modal-delete">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body center">
      <div class="modal-ico-circle-danger">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </div>
      <div class="modal-heading-line">@L["Del_Heading"]</div>
      <div class="modal-body-line">
        @L["Del_Body"] <strong id="del-item-type"></strong> "<span id="del-item-name" class="u-text-danger"></span>" @L["Del_BodySuffix"]
      </div>
    </div>
    <div class="modal-footer center">
      <button class="btn-danger" id="del-confirm-btn">@L["Del_Confirm"]</button>
      <button class="btn-secondary" data-action="modal-close" data-target="modal-delete">@L["Del_Cancel"]</button>
    </div>
  </div>
</div>
