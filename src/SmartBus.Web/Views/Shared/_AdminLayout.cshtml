<!-- ══════ MAIN ══════ -->
<div class="main">
  <div class="topbar">
    <div class="topbar-title" id="page-title">@L["Nav_Dashboard"]</div>
    <div class="topbar-right">
      <div class="tb-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input placeholder="@L["SearchShort"]" id="search-input"/>
      </div>
      <div class="date-chip" id="date-chip"></div>
      <a class="lang-btn" href="/Language/Set?culture=@_toggleCulture&returnUrl=@Uri.EscapeDataString(_returnUrl)" title="@L["LangName"]">@L["SwitchLang"]</a>
      <div class="tb-btn" title="@L["Nav_Alerts"]" onclick="showPage('alerts', document.querySelector('.nav-item:nth-child(8)'))">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg>
        <div class="tb-badge"></div>
      </div>
      <div class="tb-btn" onclick="showPage('settings', document.querySelector('.nav-item:last-child'))">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82"/></svg>
      </div>
    </div>
  </div>
  <div class="content">
    @RenderBody()
  </div>
</div>

<!-- ══════ MODAL: BUS SCHEDULE ══════ -->
<div class="modal-overlay" id="modal-trip">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-header-title">جدول رحلات الباص</div>
      <button class="modal-close-btn" onclick="closeModal('modal-trip')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <!-- Bus selector -->
      <div class="form-row full">
        <div class="form-group">
          <label class="form-label">الباص *</label>
          <select class="form-select" id="sch-bus"><option value="">— اختر باصاً —</option></select>
        </div>
      </div>

      <!-- ذهاب -->
      <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:10px;padding:14px 16px;margin-bottom:12px;">
        <div style="font-weight:700;font-size:13px;color:#15803D;margin-bottom:10px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#15803D" stroke-width="2.5" stroke-linecap="round" style="margin-left:6px;vertical-align:-2px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          ذهاب
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">وقت الانطلاق *</label>
            <input class="form-input" id="sch-morning-time" type="time" value="07:15"/>
          </div>
        </div>
      </div>

      <!-- إياب -->
      <div style="background:#EFF6FF;border:1px solid #BFDBFE;border-radius:10px;padding:14px 16px;margin-bottom:12px;">
        <div style="font-weight:700;font-size:13px;color:#1D4ED8;margin-bottom:10px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1D4ED8" stroke-width="2.5" stroke-linecap="round" style="margin-left:6px;vertical-align:-2px;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          إياب
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">وقت العودة *</label>
            <input class="form-input" id="sch-return-time" type="time" value="14:00"/>
          </div>
        </div>
      </div>

      <!-- أيام التكرار -->
      <div class="form-group">
        <label class="form-label">أيام التكرار *</label>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:6px;">
          <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer;"><input type="checkbox" class="sch-day" value="1"  style="accent-color:#3B82F6;width:15px;height:15px;"/> الأحد</label>
          <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer;"><input type="checkbox" class="sch-day" value="2"  style="accent-color:#3B82F6;width:15px;height:15px;"/> الاثنين</label>
          <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer;"><input type="checkbox" class="sch-day" value="4"  style="accent-color:#3B82F6;width:15px;height:15px;"/> الثلاثاء</label>
          <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer;"><input type="checkbox" class="sch-day" value="8"  style="accent-color:#3B82F6;width:15px;height:15px;"/> الأربعاء</label>
          <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer;"><input type="checkbox" class="sch-day" value="16" style="accent-color:#3B82F6;width:15px;height:15px;"/> الخميس</label>
          <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer;"><input type="checkbox" class="sch-day" value="32" style="accent-color:#3B82F6;width:15px;height:15px;"/> الجمعة</label>
          <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer;"><input type="checkbox" class="sch-day" value="64" style="accent-color:#3B82F6;width:15px;height:15px;"/> السبت</label>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" onclick="saveBusSchedule()">حفظ الجدول</button>
      <button class="btn-secondary" onclick="closeModal('modal-trip')">إلغاء</button>
    </div>
  </div>
</div>

<!-- ══════ MODAL: STUDENT ══════ -->
<div class="modal-overlay" id="modal-student">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-header-title" id="std-modal-title">@L["Std_AddTitle"]</div>
      <button class="modal-close-btn" onclick="closeModal('modal-student')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group"><label class="form-label">@L["Std_Name"]</label><input class="form-input" id="sf-name" placeholder="أحمد محمد الخالدي" dir="rtl"/></div>
        <div class="form-group"><label class="form-label">@L["Std_NameEn"]</label><input class="form-input" id="sf-name-en" placeholder="Ahmad Mohammad Al-Khalidi" dir="ltr"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">@L["Std_Grade"]</label>
          <select class="form-input" id="sf-grade">
            <option value="1" id="sf-g1">@L["Std_Grade1"]</option>
            <option value="2" id="sf-g2">@L["Std_Grade2"]</option>
            <option value="3" id="sf-g3">@L["Std_Grade3"]</option>
            <option value="4" id="sf-g4">@L["Std_Grade4"]</option>
            <option value="5" id="sf-g5">@L["Std_Grade5"]</option>
            <option value="6" id="sf-g6">@L["Std_Grade6"]</option>
            <option value="7" id="sf-g7">@L["Std_Grade7"]</option>
            <option value="8" id="sf-g8">@L["Std_Grade8"]</option>
            <option value="9" id="sf-g9">@L["Std_Grade9"]</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">@L["Std_Building"]</label><input class="form-input" id="sf-building" placeholder="@L["Std_BuildingHint"]" dir="ltr"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">@L["Std_Parent"]</label><input class="form-input" id="sf-parent" placeholder="محمد الخالدي" dir="rtl"/></div>
        <div class="form-group"><label class="form-label">@L["Std_ParentEn"]</label><input class="form-input" id="sf-parent-en" placeholder="Mohammad Al-Khalidi" dir="ltr"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">@L["Std_Phone"]</label><input class="form-input" id="sf-phone" placeholder="+962 79 123 4567" dir="ltr"/></div>
      </div>
      <!-- Map picker -->
      <div class="form-row full" style="margin-top:4px;">
        <div class="form-group" style="width:100%;">
          <label class="form-label">@L["Std_MapTitle"]</label>
          <div style="display:flex;gap:6px;margin-bottom:6px;">
            <input class="form-input" id="sf-map-search" placeholder="@L["Std_MapSearch"]" style="flex:1;font-size:12px;" autocomplete="off"/>
            <button type="button" id="sf-map-locate" title="موقعي الحالي" style="flex-shrink:0;width:36px;height:36px;border-radius:8px;border:1.5px solid var(--input-border);background:var(--card2);color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;" onclick="locateStudentMap()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/><circle cx="12" cy="12" r="8" stroke-dasharray="2 4"/></svg>
            </button>
          </div>
          <div id="sf-map-search-results" style="display:none;position:absolute;z-index:9999;background:var(--card);border:1px solid var(--border);border-radius:8px;width:calc(100% - 50px);max-height:160px;overflow-y:auto;box-shadow:0 4px 16px rgba(0,0,0,.3);font-size:12px;"></div>
          <div style="font-size:11px;color:var(--text3);margin-bottom:4px;">@L["Std_MapHint"]</div>
          <div id="sf-map" style="height:220px;border-radius:10px;overflow:hidden;border:1.5px solid var(--input-border);"></div>
          <input type="hidden" id="sf-lat"/>
          <input type="hidden" id="sf-lng"/>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;">
            <div>
              <label class="form-label" style="font-size:11px;">@L["Std_MapArea"]</label>
              <input class="form-input" id="sf-area" readonly placeholder="—" style="background:var(--card2);font-size:12px;"/>
            </div>
            <div>
              <label class="form-label" style="font-size:11px;">@L["Std_MapStreet"]</label>
              <input class="form-input" id="sf-street" readonly placeholder="—" style="background:var(--card2);font-size:12px;"/>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" onclick="saveStudent()">@L["Std_SaveBtn"]</button>
      <button class="btn-secondary" onclick="closeModal('modal-student')">@L["Std_Cancel"]</button>
    </div>
  </div>
</div>

<!-- ══════ MODAL: BUS ══════ -->
<div class="modal-overlay" id="modal-bus">
  <div class="modal-box" style="max-width:600px;">
    <div class="modal-header">
      <div class="modal-header-title" id="bus-modal-title">@(_isRtl ? "إضافة باص جديد" : "Add New Bus")</div>
      <button class="modal-close-btn" onclick="closeModal('modal-bus')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <!-- Row 1: Plate + Capacity -->
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@(_isRtl ? "رقم الباص" : "Bus Number")</label>
          <input class="form-input" id="bf-num" placeholder="@(_isRtl ? "مثال: 42-ABC" : "e.g. 42-ABC")" dir="ltr"/>
        </div>
        <div class="form-group">
          <label class="form-label">@(_isRtl ? "الطاقة الاستيعابية" : "Capacity")</label>
          <input class="form-input" id="bf-cap" type="number" min="1" max="100" placeholder="30"/>
        </div>
      </div>
      <!-- Row 2: Status -->
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@(_isRtl ? "الحالة" : "Status")</label>
          <select class="form-input" id="bf-status">
            <option value="Inactive">@(_isRtl ? "غير نشط" : "Inactive")</option>
            <option value="Active">@(_isRtl ? "نشط" : "Active")</option>
            <option value="OnRoute">@(_isRtl ? "في الطريق" : "On Route")</option>
            <option value="Maintenance">@(_isRtl ? "صيانة" : "Maintenance")</option>
            <option value="OutOfService">@(_isRtl ? "خارج الخدمة" : "Out of Service")</option>
          </select>
        </div>
        <div class="form-group"></div>
      </div>
      <!-- Row 3: Driver + Assistant -->
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@(_isRtl ? "السائق" : "Driver")</label>
          <select class="form-input" id="bf-driver">
            <option value="">@(_isRtl ? "— اختر سائقاً —" : "— Select Driver —")</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">@(_isRtl ? "المساعد" : "Assistant")</label>
          <select class="form-input" id="bf-assistant">
            <option value="">@(_isRtl ? "— اختر مساعداً —" : "— Select Assistant —")</option>
          </select>
        </div>
      </div>
      <!-- Students multi-select -->
      <div class="form-group" style="margin-top:6px;">
        <label class="form-label">@(_isRtl ? "الطلاب المسندون" : "Assigned Students")</label>
        <div style="position:relative;">
          <input class="form-input" id="bf-student-search"
                 placeholder="@(_isRtl ? "ابحث باسم الطالب أو الحي..." : "Search by name or area...")"
                 autocomplete="off" oninput="filterBusStudents(this.value)"/>
        </div>
        <div id="bf-students-list"
             style="border:1.5px solid var(--border2);border-radius:10px;max-height:200px;overflow-y:auto;margin-top:6px;background:var(--bg);">
          <div style="padding:16px;text-align:center;color:var(--text3);font-size:12px;" id="bf-students-loading">
            @(_isRtl ? "جاري التحميل..." : "Loading...")
          </div>
        </div>
        <div style="margin-top:5px;font-size:11px;color:var(--text3);">
          <span id="bf-selected-count">0</span> @(_isRtl ? "طالب مختار" : "students selected")
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" onclick="saveBus()">@(_isRtl ? "💾 حفظ الباص" : "💾 Save Bus")</button>
      <button class="btn-secondary" onclick="closeModal('modal-bus')">@(_isRtl ? "إلغاء" : "Cancel")</button>
    </div>
  </div>
</div>

<!-- ══════ MODAL: DRIVER ══════ -->
<div class="modal-overlay" id="modal-driver">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-header-title" id="driver-modal-title">@L["Driver_AddTitle"]</div>
      <button class="modal-close-btn" onclick="closeModal('modal-driver')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="df-id" />
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["Driver_NameAr"]</label>
          <input type="text" id="df-name" class="form-input" placeholder="اسم السائق بالعربية" dir="rtl" />
        </div>
        <div class="form-group">
          <label class="form-label">@L["Driver_NameEn"]</label>
          <input type="text" id="df-name-en" class="form-input" placeholder="Driver name in English" dir="ltr" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["Driver_Phone"]</label>
          <input type="text" id="df-phone" class="form-input" placeholder="05xxxxxxxx" />
        </div>
        <div class="form-group">
          <label class="form-label">@L["Driver_License"]</label>
          <input type="text" id="df-license" class="form-input" placeholder="رقم رخصة القيادة" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">@L["Driver_Type"]</label>
          <select id="df-type" class="form-input">
            <option value="Driver"    id="df-type-opt-driver">@L["Driver_TypeDriver"]</option>
            <option value="Assistant" id="df-type-opt-assist">@L["Driver_TypeAssist"]</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">@L["Driver_Status"]</label>
          <select id="df-active" class="form-input">
            <option value="true" id="df-active-opt-true">@L["Driver_Active"]</option>
            <option value="false" id="df-active-opt-false">@L["Driver_Inactive"]</option>
          </select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" onclick="saveDriver()">@L["Driver_SaveBtn"]</button>
      <button class="btn-secondary" onclick="closeModal('modal-driver')">@L["Driver_Cancel"]</button>
    </div>
  </div>
</div>

<!-- ══════ MODAL: DELETE ══════ -->
<div class="modal-overlay" id="modal-delete">
  <div class="modal-box" style="max-width:380px;">
    <div class="modal-header">
      <div class="modal-header-title" style="color:#DC2626;">@L["Del_Title"]</div>
      <button class="modal-close-btn" onclick="closeModal('modal-delete')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" style="text-align:center;padding:28px 22px;">
      <div style="width:56px;height:56px;border-radius:50%;background:#FEF2F2;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </div>
      <div style="font-size:15px;font-weight:700;color:#111;font-family:'Cairo',sans-serif;margin-bottom:8px;" id="del-heading">@L["Del_Heading"]</div>
      <div style="font-size:13px;color:#475569;font-family:'Cairo',sans-serif;line-height:1.5;" id="del-body-text">
        @L["Del_Body"] <strong id="del-item-type"></strong> "<span id="del-item-name" style="color:#DC2626;"></span>" @L["Del_BodySuffix"]
      </div>
    </div>
    <div class="modal-footer" style="justify-content:center;">
      <button class="btn-danger" id="del-confirm-btn">@L["Del_Confirm"]</button>
      <button class="btn-secondary" id="del-cancel-btn" onclick="closeModal('modal-delete')">@L["Del_Cancel"]</button>
    </div>
  </div>
</div>

<!-- MODAL: CHANGE PASSWORD -->
<div class="modal-overlay" id="modal-change-password">
  <div class="modal-box" style="max-width:420px;">
    <div class="modal-header">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:32px;height:32px;border-radius:9px;background:#F5F3FF;display:flex;align-items:center;justify-content:center;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="modal-header-title">تغيير كلمة المرور</div>
      </div>
      <button class="modal-close-btn" onclick="closeModal('modal-change-password')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
      <div class="form-group">
        <label class="form-label">كلمة المرور الحالية</label>
        <input type="password" id="cp-current" class="form-input" placeholder="••••••••" autocomplete="current-password"/>
        <span class="form-err" id="err-cp-current" style="font-size:11px;color:#EF4444;margin-top:3px;display:none;">هذا الحقل مطلوب</span>
      </div>
      <div class="form-group">
        <label class="form-label">كلمة المرور الجديدة</label>
        <input type="password" id="cp-new" class="form-input" placeholder="8 أحرف على الأقل" autocomplete="new-password"/>
        <span class="form-err" id="err-cp-new" style="font-size:11px;color:#EF4444;margin-top:3px;display:none;">8 أحرف على الأقل</span>
      </div>
      <div class="form-group">
        <label class="form-label">تأكيد كلمة المرور</label>
        <input type="password" id="cp-confirm" class="form-input" placeholder="••••••••" autocomplete="new-password"/>
        <span class="form-err" id="err-cp-confirm" style="font-size:11px;color:#EF4444;margin-top:3px;display:none;">كلمتا المرور غير متطابقتين</span>
      </div>
      <div id="cp-server-err" style="display:none;background:#FEF2F2;border:1px solid #FECACA;border-radius:8px;padding:10px 12px;font-size:12px;color:#DC2626;"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-primary" id="btn-save-password" onclick="changePassword()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        حفظ كلمة المرور
      </button>
      <button class="btn-secondary" onclick="closeModal('modal-change-password')">إلغاء</button>
    </div>
  </div>
</div>

<script>
window.T = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
