    stdMapArea     = L["Std_MapArea"].Value,
    stdMapStreet   = L["Std_MapStreet"].Value,
    stdMapLoading  = L["Std_MapLoading"].Value,
    stdMapNoResult = L["Std_MapNoResult"].Value,
    stdAddTitle  = L["Std_AddTitle"].Value,
    stdEditTitle = L["Std_EditTitle"].Value,
    stdGrade1    = L["Std_Grade1"].Value,
    stdGrade2    = L["Std_Grade2"].Value,
