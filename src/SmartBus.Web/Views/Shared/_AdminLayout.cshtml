@{
    var _isRtl  = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var _dir    = _isRtl ? "rtl" : "ltr";
    var _culture        = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var _toggleCulture  = _isRtl ? "en" : "ar";
    var _returnUrl      = Context.Request.Path + Context.Request.QueryString;
    var _schoolCity     = (string)(ViewBag.SchoolCity ?? string.Empty);
    var _schoolName     = (string)(ViewBag.SchoolName ?? string.Empty);
}
<!DOCTYPE html>
<html lang="@_culture" dir="@_dir">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"] - SmartBus</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
:root{
  --y:#FFD700; --yl:#FFFDE7; --yd:#B8960C;
  --bl:#3B82F6; --bll:#EFF6FF; --bld:#1E40AF;
  --g:#22C55E; --gl:#F0FDF4; --gd:#15803D;
  --r:#EF4444; --rl:#FEF2F2; --rd:#B91C1C;
  --o:#F97316; --ol:#FFF7ED;
  --pu:#8B5CF6; --pul:#F5F3FF;
  --sidebar:#FFFFFF; --sidebar2:#FFFDE7; --sidebar3:#FFE066;
  --bg:#F9FAFB; --card:#FFFFFF;
  --text:#111111; --text2:#475569; --text3:#9CA3AF;
  --border:#E5E7EB; --border2:#D1D5DB;
  --shadow:0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.03);
  --shadow2:0 4px 16px rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;font-size:14px;}

/* ══ SIDEBAR ══ */
.sidebar{width:240px;background:var(--sidebar);min-height:100vh;display:flex;flex-direction:column;flex-shrink:0;position:fixed;right:0;top:0;bottom:0;z-index:100;border-left:1px solid var(--border);}
.sidebar-logo{padding:20px 20px 14px;border-bottom:2px solid var(--y);}
.logo-mark{display:flex;align-items:center;gap:10px;}
.logo-icon{width:36px;height:36px;background:var(--y);border-radius:10px;display:flex;align-items:center;justify-content:center;}
.logo-name{font-size:18px;font-weight:800;color:var(--text);letter-spacing:-.3px;}
.logo-sub{font-size:10px;color:var(--text3);margin-top:1px;}
.sidebar-school{margin:12px 14px;background:var(--yl);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:8px;border:1px solid var(--y);}
.school-av{width:30px;height:30px;border-radius:8px;background:var(--y);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#111;flex-shrink:0;}
.school-name{font-size:12px;font-weight:700;color:var(--text);}
.school-plan{font-size:10px;color:var(--yd);margin-top:1px;}
.sidebar-nav{flex:1;padding:8px 0;overflow-y:auto;}
.nav-section{font-size:10px;font-weight:700;color:var(--text3);padding:14px 20px 4px;letter-spacing:.08em;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 20px;cursor:pointer;transition:all .15s;border-radius:0;position:relative;}
.nav-item:hover{background:var(--yl);}
.nav-item.active{background:var(--y);}
.nav-item.active::before{content:'';position:absolute;right:0;top:4px;bottom:4px;width:3px;background:var(--yd);border-radius:2px 0 0 2px;}
.nav-icon{width:18px;height:18px;flex-shrink:0;opacity:.5;}
.nav-item.active .nav-icon{opacity:1;}
.nav-item.active .nav-label{color:#111;font-weight:700;}
.nav-label{font-size:13px;color:var(--text2);font-weight:500;}
.nav-badge{margin-right:auto;background:var(--r);border-radius:20px;padding:1px 7px;font-size:10px;font-weight:700;color:#fff;}
.nav-badge.y{background:var(--yd);color:#fff;}
.sidebar-bottom{padding:14px;border-top:1px solid var(--border);}
.user-row{display:flex;align-items:center;gap:10px;}
.user-av{width:34px;height:34px;border-radius:50%;background:var(--y);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#111;flex-shrink:0;}
.user-name{font-size:12px;font-weight:700;color:var(--text);}
.user-role{font-size:10px;color:var(--text3);margin-top:1px;}

/* ══ MAIN ══ */
.main{margin-right:240px;flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{background:#fff;border-bottom:2px solid var(--y);padding:0 28px;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.topbar-title{font-size:18px;font-weight:700;color:var(--text);}
.topbar-right{display:flex;align-items:center;gap:12px;}
.tb-btn{width:36px;height:36px;border-radius:50%;background:var(--bg);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;}
.tb-badge{width:8px;height:8px;border-radius:50%;background:var(--r);border:2px solid var(--card);position:absolute;top:1px;right:1px;}
.tb-search{display:flex;align-items:center;gap:8px;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:7px 14px;min-width:220px;}
.tb-search input{border:none;background:transparent;font-size:13px;font-family:'Cairo',sans-serif;color:var(--text);outline:none;width:100%;}
.tb-search input::placeholder{color:var(--text3);}
.date-chip{background:var(--y);border-radius:8px;padding:5px 12px;font-size:12px;font-weight:700;color:#111;}
.content{padding:24px 28px;flex:1;}

/* PAGE */
.page{display:none;}
.page.active{display:block;}

/* ══ STAT CARDS ══ */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.stat-card{background:var(--card);border-radius:16px;border:1px solid var(--border);padding:18px 20px;box-shadow:var(--shadow);position:relative;overflow:hidden;}
.stat-card::after{content:'';position:absolute;top:-20px;left:-20px;width:80px;height:80px;border-radius:50%;opacity:.06;}
.stat-card.blue::after{background:var(--bl);}
.stat-card.green::after{background:var(--g);}
.stat-card.yellow::after{background:var(--y);}
.stat-card.red::after{background:var(--r);}
.stat-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:12px;}
.stat-num{font-size:28px;font-weight:800;color:var(--text);line-height:1;margin-bottom:3px;}
.stat-label{font-size:12px;color:var(--text2);}
.stat-change{font-size:11px;margin-top:6px;display:flex;align-items:center;gap:3px;}
.stat-change.up{color:var(--gd);}
.stat-change.down{color:var(--rd);}

/* ══ GRID LAYOUT ══ */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;}
.grid-3{display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:24px;}

/* ══ CARD ══ */
.card{background:var(--card);border-radius:16px;border:1px solid var(--border);box-shadow:var(--shadow);overflow:hidden;}
.card-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:14px;font-weight:700;color:var(--text);}
.card-sub{font-size:11px;color:var(--text3);margin-top:1px;}
.card-action{font-size:12px;color:var(--bl);font-weight:600;cursor:pointer;}
.card-body{padding:16px 20px;}

/* ══ MAP ══ */
.map-card{background:var(--card);border-radius:16px;border:1px solid var(--border);overflow:hidden;box-shadow:var(--shadow);}
.map-area{height:320px;background:linear-gradient(135deg,#DCF2EF 0%,#C8E9E5 100%);position:relative;overflow:hidden;}
.map-grid-h{position:absolute;left:0;right:0;border-top:1px solid rgba(178,223,219,.5);}
.map-grid-v{position:absolute;top:0;bottom:0;border-left:1px solid rgba(178,223,219,.5);}
.map-road-h{position:absolute;left:0;right:0;background:rgba(255,255,255,.7);}
.map-road-v{position:absolute;top:0;bottom:0;background:rgba(255,255,255,.7);}
.map-bus{position:absolute;transform:translate(-50%,-50%);z-index:5;cursor:pointer;}
.mbus-pin{width:36px;height:36px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.2);display:flex;align-items:center;justify-content:center;}
.mbus-pulse{position:absolute;border-radius:50%;animation:mpulse 2s infinite;transform:translate(-50%,-50%);}
@@keyframes mpulse{0%{opacity:.6;transform:translate(-50%,-50%) scale(1);}100%{opacity:0;transform:translate(-50%,-50%) scale(2.2);}}
.mbus-label{position:absolute;background:#fff;border-radius:6px;padding:2px 8px;font-size:10px;font-weight:700;white-space:nowrap;box-shadow:0 1px 4px rgba(0,0,0,.1);bottom:-28px;left:50%;transform:translateX(-50%);}
.map-controls{position:absolute;bottom:12px;right:12px;display:flex;flex-direction:column;gap:2px;z-index:10;}
.mctrl{width:28px;height:28px;background:#fff;border-radius:7px;box-shadow:0 1px 4px rgba(0,0,0,.15);display:flex;align-items:center;justify-content:center;cursor:pointer;}
.map-legend{padding:10px 16px;background:var(--card);border-top:1px solid var(--border);display:flex;gap:16px;align-items:center;}
.legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2);}
.legend-dot{width:10px;height:10px;border-radius:50%;}

/* ══ TRIP LIST ══ */
.trip-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.trip-row:last-child{border-bottom:none;}
.trip-status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.trip-info{flex:1;}
.trip-name{font-size:13px;font-weight:700;color:var(--text);}
.trip-meta{font-size:11px;color:var(--text3);margin-top:2px;}
.trip-badge{border-radius:20px;padding:3px 10px;flex-shrink:0;}
.trip-badge span{font-size:11px;font-weight:700;}

/* ══ TABLE ══ */
.table{width:100%;border-collapse:collapse;}
.table th{text-align:right;padding:10px 14px;font-size:11px;font-weight:700;color:var(--text3);border-bottom:2px solid var(--border);background:var(--bg);letter-spacing:.04em;}
.table td{padding:12px 14px;border-bottom:1px solid var(--border);font-size:13px;color:var(--text);}
.table tr:last-child td{border-bottom:none;}
.table tr:hover td{background:var(--bg);}
.table-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;}
.td-name{font-weight:700;}
.td-sub{font-size:11px;color:var(--text3);margin-top:1px;}
.td-badge{border-radius:20px;padding:2px 9px;display:inline-block;}
.td-badge span{font-size:10px;font-weight:700;}

/* ══ ALERTS ══ */
.alert-item{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);}
.alert-item:last-child{border-bottom:none;}
.alert-icon{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.alert-title{font-size:13px;font-weight:700;color:var(--text);}
.alert-body{font-size:11px;color:var(--text2);margin-top:2px;line-height:1.4;}
.alert-time{font-size:10px;color:var(--text3);margin-top:3px;}
.alert-actions{display:flex;gap:6px;margin-top:6px;}
.alert-btn{border-radius:7px;padding:4px 10px;font-size:11px;font-weight:600;cursor:pointer;border:none;font-family:'Cairo',sans-serif;}

/* ══ ATTENDANCE CHART ══ */
.chart-bars{display:flex;align-items:flex-end;gap:6px;height:100px;padding:0 4px;}
.bar-group{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;}
.bar-wrap{width:100%;display:flex;align-items:flex-end;gap:2px;height:80px;}
.bar{border-radius:4px 4px 0 0;transition:height .3s;flex:1;}
.bar-label{font-size:9px;color:var(--text3);}

/* ══ FILTER BAR ══ */
.filter-bar{display:flex;gap:10px;margin-bottom:16px;align-items:center;}
.filter-btn{border:1px solid var(--border);border-radius:9px;padding:7px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:'Cairo',sans-serif;color:var(--text2);background:var(--card);}
.filter-btn.active{background:#111;color:#fff;border-color:#111;}
.add-btn{background:var(--y);border-radius:9px;padding:8px 16px;font-size:13px;font-weight:700;cursor:pointer;border:none;font-family:'Cairo',sans-serif;color:#111;display:flex;align-items:center;gap:6px;margin-right:auto;}

/* ══ REPORTS ══ */
.report-stat{background:var(--card);border-radius:14px;border:1px solid var(--border);padding:18px;text-align:center;}
.report-num{font-size:32px;font-weight:800;color:var(--text);}
.report-lbl{font-size:12px;color:var(--text3);margin-top:4px;}
.report-sub{font-size:11px;margin-top:6px;}

/* ══ SETTINGS ══ */
.settings-section{margin-bottom:20px;}
.settings-section-title{font-size:13px;font-weight:700;color:var(--text3);margin-bottom:10px;letter-spacing:.04em;}
.setting-row{background:var(--card);border-radius:12px;border:1px solid var(--border);padding:14px 16px;display:flex;align-items:center;gap:12px;margin-bottom:8px;}
.setting-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.setting-title{font-size:13px;font-weight:700;color:var(--text);}
.setting-sub{font-size:11px;color:var(--text3);margin-top:1px;}
.toggle{width:42px;height:24px;border-radius:12px;position:relative;cursor:pointer;flex-shrink:0;margin-right:auto;}
.toggle.on{background:var(--y);}
.toggle.off{background:var(--border2);}
.toggle-knob{position:absolute;top:3px;width:18px;height:18px;background:#fff;border-radius:50%;transition:right .15s;}
.toggle.on .toggle-knob{right:3px;}
.toggle.off .toggle-knob{right:21px;}
.setting-value{font-size:12px;color:var(--text3);margin-right:auto;}
.setting-arrow{color:var(--text3);}

/* ══ MODAL ══ */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal-box{background:#fff;border-radius:20px;width:100%;max-width:480px;box-shadow:0 20px 60px rgba(0,0,0,.15);overflow:hidden;animation:mslide .2s ease;}
@@keyframes mslide{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}
.modal-header{padding:18px 22px;border-bottom:1px solid #E5E7EB;display:flex;align-items:center;justify-content:space-between;}
.modal-header-title{font-size:16px;font-weight:800;color:#111;font-family:'Cairo',sans-serif;}
.modal-close-btn{width:30px;height:30px;border-radius:50%;background:#F3F4F6;display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;}
.modal-body{padding:20px 22px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
.form-row.full{grid-template-columns:1fr;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-label{font-size:12px;font-weight:700;color:#475569;font-family:'Cairo',sans-serif;letter-spacing:.02em;}
.form-input{border:1.5px solid #E5E7EB;border-radius:10px;padding:9px 12px;font-size:13px;color:#111;font-family:'Cairo',sans-serif;outline:none;background:#F9FAFB;transition:border-color .15s;}
.form-input:focus{border-color:#FFD700;background:#fff;}
.form-select{border:1.5px solid #E5E7EB;border-radius:10px;padding:9px 12px;font-size:13px;color:#111;font-family:'Cairo',sans-serif;outline:none;background:#F9FAFB;appearance:none;cursor:pointer;}
.form-select:focus{border-color:#FFD700;}
.modal-footer{padding:14px 22px;border-top:1px solid #E5E7EB;display:flex;gap:10px;justify-content:flex-start;}
.btn-primary{background:#FFD700;border:none;border-radius:10px;padding:10px 22px;font-size:13px;font-weight:700;color:#111;font-family:'Cairo',sans-serif;cursor:pointer;}
.btn-primary:hover{background:#FFC800;}
.btn-secondary{background:#F3F4F6;border:none;border-radius:10px;padding:10px 22px;font-size:13px;font-weight:700;color:#475569;font-family:'Cairo',sans-serif;cursor:pointer;}
.btn-danger{background:#FEF2F2;border:1.5px solid #FECACA;border-radius:10px;padding:10px 22px;font-size:13px;font-weight:700;color:#DC2626;font-family:'Cairo',sans-serif;cursor:pointer;}
.tbl-btn{width:28px;height:28px;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;border:none;}
.tbl-edit{background:#EFF6FF;}
.tbl-del{background:#FEF2F2;}
.tbl-actions{display:flex;gap:6px;}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* ══ LANGUAGE BUTTON ══ */
.lang-btn{height:32px;min-width:36px;border-radius:8px;border:1px solid var(--border);background:var(--card);font-size:12px;font-weight:700;font-family:'Cairo',sans-serif;color:var(--text2);cursor:pointer;padding:0 10px;transition:all .15s;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;}
.lang-btn:hover{background:var(--y);border-color:var(--yd);color:#111;}

/* ══ LTR OVERRIDES ══ */
[dir="ltr"] .sidebar{right:auto;left:0;border-left:none;border-right:1px solid var(--border);}
[dir="ltr"] .main{margin-right:0;margin-left:240px;}
[dir="ltr"] .nav-item.active::before{right:auto;left:0;border-radius:0 2px 2px 0;}
[dir="ltr"] .nav-badge{margin-right:unset;margin-left:auto;}
[dir="ltr"] .add-btn{margin-right:0;margin-left:auto;}
[dir="ltr"] .table th{text-align:left;}
[dir="ltr"] .toggle.on  .toggle-knob{right:auto;left:3px;}
[dir="ltr"] .toggle.off .toggle-knob{right:auto;left:21px;}
[dir="ltr"] .setting-value,.setting-arrow{margin-right:unset;}
[dir="ltr"] .toggle{margin-right:0;margin-left:auto;}
</style>
</head>
<body>

<!-- ══════ SIDEBAR ══════ -->
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark">
      <div class="logo-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round">
          <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/>
          <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      </div>
      <div><div class="logo-name">SmartBus</div><div class="logo-sub">@(_isRtl ? "لوحة الإدارة" : "Admin Panel")</div></div>
    </div>
  </div>
  <div class="sidebar-school">
    <div class="school-av">@(_schoolName.Length > 0 ? _schoolName[0].ToString() : "S")</div>
    <div>
      <div class="school-name">@(_schoolName.Length > 0 ? _schoolName : "SmartBus School")</div>
      <div class="school-plan" id="school-city-label">@(_schoolCity.Length > 0 ? _schoolCity : "")</div>
    </div>
  </div>
  <div class="sidebar-nav">
    <div class="nav-section">@L["Nav_Main"]</div>
    <div class="nav-item active" onclick="showPage('dashboard', this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2" stroke-linecap="round">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
      </svg>
      <span class="nav-label">@L["Nav_Dashboard"]</span>
    </div>
    <div class="nav-item" onclick="showPage('trips', this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round">
        <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/>
        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span class="nav-label">@L["Nav_Trips"]</span>
      <div class="nav-badge y" id="trips-badge">0</div>
    </div>
    <div class="nav-section">@L["Nav_Mgmt"]</div>
    <div class="nav-item" onclick="showPage('students', this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span class="nav-label">@L["Nav_Students"]</span>
    </div>
    <div class="nav-item" onclick="showPage('drivers', this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
      </svg>
      <span class="nav-label">@L["Nav_Drivers"]</span>
    </div>
    <div class="nav-item" onclick="showPage('buses', this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round">
        <rect x="1" y="3" width="15" height="13" rx="2"/>
