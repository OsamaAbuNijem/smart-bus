@model AdminPageViewModel
@{
    var isRtl         = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var toggleCulture = isRtl ? "en" : "ar";
    var returnUrl     = Context.Request.Path + Context.Request.QueryString;
}

<div class="topbar">
  <div class="topbar-title">@Model.PageTitle</div>
  <div class="topbar-right">
    <div class="date-chip" id="date-chip"></div>
    <a class="lang-btn" href="/Language/Set?culture=@toggleCulture&returnUrl=@Uri.EscapeDataString(returnUrl)" title="@L["LangName"]">@L["SwitchLang"]</a>
    <a class="tb-btn" href="/Alerts" title="@L["Nav_Alerts"]">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      </svg>
      <div class="tb-badge"></div>
    </a>
    <a class="tb-btn" href="/Settings">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82"/>
      </svg>
    </a>
  </div>
</div>
