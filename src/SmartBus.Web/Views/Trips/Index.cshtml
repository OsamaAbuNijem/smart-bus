@model AdminPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

<input type="hidden" id="trips-page" value="1"/>

<div class="filter-bar panel">
  <div class="filter-group">
    @* Honeypot decoys — Chrome re-runs autofill after every DOM change. *@
    <input type="text"     class="u-honeypot" tabindex="-1" aria-hidden="true"
           autocomplete="username"          name="fake-user"/>
    <input type="password" class="u-honeypot" tabindex="-1" aria-hidden="true"
           autocomplete="current-password"  name="fake-pass"/>

    <input type="search"
           id="trip-filter-name"
           name="search-person"
           class="form-input"
           placeholder="@L["Trip_SearchPerson"]"
           value=""
           readonly
           onfocus="this.removeAttribute('readonly')"
           onblur="this.setAttribute('readonly','')"
           autocomplete="off"
           autocorrect="off"
           autocapitalize="none"
           spellcheck="false"
           data-lpignore="true"
           data-form-type="other"
           oninput="trips.debouncedSearch()"/>

    <input id="trip-filter-date"
           type="date"
           class="form-input"
           aria-label="@L["Trip_FilterDate"]"
           onchange="trips.load(1)"/>

    <select id="trip-filter-status"
            class="form-input"
            aria-label="@L["Trip_FilterStatus"]"
            onchange="trips.load(1)">
      <option value="">@L["Trip_FilterStatus"] — @L["Pager_All"]</option>
      <option value="Scheduled">@L["Trip_StatusScheduled"]</option>
      <option value="InProgress">@L["Trip_StatusInProgress"]</option>
      <option value="Completed">@L["Trip_StatusCompleted"]</option>
      <option value="Delayed">@L["Trip_StatusDelayed"]</option>
      <option value="Cancelled">@L["Trip_StatusCancelled"]</option>
    </select>

    <button class="btn-ghost" onclick="trips.clearFilter()"
            aria-label="@L["Trip_ClearFilter"]" title="@L["Trip_ClearFilter"]">
      <svg class="ico" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      @L["Trip_ClearFilter"]
    </button>
  </div>

  <div class="action-group">
    <button class="add-btn" onclick="trips.generate()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      @L["Trip_GenerateBtn"]
    </button>
  </div>
</div>

<div class="card">
  <table class="table">
    <thead>
      <tr>
        <th scope="col">@L["Trip_ColNumber"]</th>
        <th scope="col">@L["Trip_ColDriver"]</th>
        <th scope="col">@L["Trip_ColAssistant"]</th>
        <th scope="col">@L["Trip_ColBus"]</th>
        <th scope="col">@L["Trip_ColType"]</th>
        <th scope="col">@L["Trip_ColDate"]</th>
        <th scope="col">@L["Trip_ColTime"]</th>
        <th scope="col">@L["Trip_ColStatus"]</th>
        <th scope="col"></th>
      </tr>
    </thead>
    <tbody id="trips-tbody">
      <tr><td colspan="9" class="u-loading-state">@L["Trip_Loading"]</td></tr>
    </tbody>
  </table>
  <div class="table-pager">
    <div class="u-flex u-items-center u-gap-12">
      <span class="count-pill accent" aria-live="polite">
        <span>@L["Trip_TotalLabel"]</span>
        <span class="count" id="trips-total">0</span>
      </span>
      <span class="table-pager-info" id="trips-pager-info" aria-live="polite"></span>
    </div>
    <div class="table-pager-controls">
      <button class="filter-btn" id="trips-prev" onclick="trips.prev()">@L["Pager_Prev"]</button>
      <button class="filter-btn" id="trips-next" onclick="trips.next()">@L["Pager_Next"]</button>
    </div>
  </div>
</div>

@* Trip students modal *@
<div class="modal-overlay" id="modal-trip-students">
  <div class="modal-box xl">
    <div class="modal-header">
      <div>
        <div class="modal-header-title" id="trip-students-title">@L["Trip_StudentsTitle"]</div>
        <div class="u-text-11 u-text-muted u-mt-2" id="trip-students-sub"></div>
      </div>
      <button class="modal-close-btn" onclick="SB.closeModal('modal-trip-students')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body flush">
      <div id="trip-students-body" class="modal-body-scroll">
        <div class="u-empty-state">@L["Trip_Loading"]</div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/admin/trips.js" asp-append-version="true"></script>
}
