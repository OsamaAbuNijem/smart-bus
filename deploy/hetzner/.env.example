# Copy to .env on the server, fill in the real values, never commit.
# `docker compose --env-file .env -f docker-compose.yml up -d --build`

# Your apex domain. Subdomains api.${DOMAIN} and admin.${DOMAIN} must
# already resolve to this VPS via A records.
DOMAIN=tilmezbus.com

# Postgres credentials — used by both the postgres container and the API.
POSTGRES_DB=tilmezbus
POSTGRES_USER=tilmezbus
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# JWT signing key — generate with: openssl rand -base64 64
JWT_KEY=REPLACE_WITH_64_RANDOM_BYTES_BASE64

# Seq log viewer admin password (any strong string).
# Generate with: openssl rand -base64 24 | tr -d '/+=' | head -c 24
SEQ_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Firebase service-account JSON (the entire file on ONE line, as JSON).
# Generate with:
#   jq -c . firbase/smart-bus-firebase-firebase-adminsdk-fbsvc-XXX.json
# Then paste the output here. Single-line. Keep the surrounding quotes off.
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"smart-bus-firebase","..."}

# Twilio — WhatsApp OTP delivery. Account SID + Auth Token from
# console.twilio.com. Use a Messaging Service (preferred) so Twilio
# picks the approved WhatsApp sender from the service's pool — leave
# TWILIO_WHATSAPP_FROM blank in that case. For the sandbox, set
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 and leave the service blank.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=
# Approved WhatsApp Authentication template SID (HX…). Required so
# OTPs send outside the 24-hour conversation window; Meta drops
# freeform text in that case. Create in Twilio Console → Messaging →
# Content Template Builder → "Authentication" category.
TWILIO_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
